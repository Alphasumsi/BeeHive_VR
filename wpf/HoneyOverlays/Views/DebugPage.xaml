<UserControl x:Class="HoneyOverlays.Views.DebugPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HoneyOverlays.ViewModels"
             xmlns:svc="clr-namespace:HoneyOverlays.Services"
             mc:Ignorable="d"
             Background="{StaticResource BgPrimary}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- iRacing Live -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Liste -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="0,0,0,1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Border Padding="14,8" BorderBrush="{StaticResource AccentText}"
                        BorderThickness="0,0,0,2">
                    <TextBlock Text="Debug Console" FontSize="15" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- iRacing Live-Status -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderTertiary}" BorderThickness="1"
                CornerRadius="6" Background="{StaticResource BgSecondary}"
                Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Connection -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,3">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="13" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Text" Value="Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Car -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Car"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataContext.LiveCar, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,3"/>

                <!-- Track -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Track"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DataContext.LiveTrack, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,3"/>

                <!-- Session Type -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Session type"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DataContext.LiveSession, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,3"/>

                <!-- Session State -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Session state"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DataContext.LiveSessionState, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,3"/>

                <!-- Location -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Location"
                           FontSize="12" Foreground="{StaticResource TextTertiary}"
                           VerticalAlignment="Center" Margin="0,3"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DataContext.LiveLocation, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,3"/>
            </Grid>
        </Border>

        <!-- Toolbar: Filter + Buttons -->
        <DockPanel Grid.Row="2" Margin="0,0,0,10" LastChildFill="False">
            <!-- Filter-Checkboxen links -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Show:" FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <CheckBox Content="Info" IsChecked="{Binding ShowInfo}"
                          Margin="0,0,12,0" VerticalAlignment="Center"/>
                <CheckBox Content="Warn" IsChecked="{Binding ShowWarn}"
                          Margin="0,0,12,0" VerticalAlignment="Center"/>
                <CheckBox Content="Error" IsChecked="{Binding ShowError}"
                          Margin="0,0,20,0" VerticalAlignment="Center"/>

                <Border Width="1" Height="18" Background="{StaticResource BorderTertiary}"
                        Margin="0,0,16,0"/>

                <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScroll}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Buttons rechts -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Open log file"
                        Padding="10,5"
                        Click="OpenLogFile_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Copy log"
                        Padding="10,5"
                        Click="CopyLog_Click"
                        Margin="0,0,8,0"
                        ToolTip="Copy currently visible log entries to clipboard"/>
                <Button Content="Clear"
                        Padding="10,5"
                        Command="{Binding ClearCommand}"
                        Margin="0,0,16,0"/>
                <!-- Step 4b test trigger: push a hardcoded atlas layout to
                     Electron over \\.\pipe\BeeHiveVR. Click cycles through
                     three preset poses so we can verify live updates. -->
                <Button Content="Send test atlas layout"
                        Padding="10,5"
                        Click="SendTestAtlasLayout_Click"
                        ToolTip="Push a setAtlasLayout message to the Electron Atlas-Renderer"/>
            </StackPanel>
        </DockPanel>

        <!-- Log-Einträge -->
        <Border Grid.Row="3" BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="1" CornerRadius="4"
                Background="{StaticResource BgTertiary}">
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding EntriesView}"
                              x:Name="LogList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type svc:LogEntry}">
                            <Grid Margin="8,3,8,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <!-- Timestamp -->
                                    <ColumnDefinition Width="60"/>
                                    <!-- Level -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Message -->
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss.fff}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiary}"
                                           VerticalAlignment="Top"/>

                                <!-- Level (color-coded) -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Level}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource AccentText}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource DangerText}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Message + optional Exception -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Message}"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Exception}"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiary}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding Exception,
                                                            Converter={StaticResource NullToVis}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>