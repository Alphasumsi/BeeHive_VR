<Window x:Class="HoneyOverlays.Views.AddOverlayWindowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Add window overlay"
        Width="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="1"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderSecondary}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1" Height="32"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Add window overlay"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <Button HorizontalAlignment="Right" Width="40" Height="32"
                            Click="Cancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <Path Data="M0,0 L10,10 M10,0 L0,10"
                                          Stroke="{StaticResource TextPrimary}"
                                          StrokeThickness="1"
                                          Width="10" Height="10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Body — Name + Window-Auswahl -->
            <StackPanel Grid.Row="1" Margin="20,18,20,18">

                <TextBlock Text="Name"
                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox"
                         Height="30"
                         FontFamily="Segoe UI Variable, Segoe UI"
                         HorizontalContentAlignment="Left"
                         TextChanged="NameBox_TextChanged"
                         Margin="0,0,0,14"/>

                <TextBlock Text="Window"
                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto" MinWidth="77"/>
                        <ColumnDefinition Width="Auto" MinWidth="78"/>
                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="WindowCombo"
                              Grid.Column="0"
                              SelectionChanged="WindowCombo_SelectionChanged" Margin="0,7,0,7"/>

                    <Button Grid.Column="1" Content="Refresh" Margin="6,7,0,7" Padding="12,0"
                            ToolTip="Refresh window list"
                            Click="Refresh_Click"/>

                    <CheckBox Grid.Column="2"
                              x:Name="ExtendedToggle"
                              Style="{StaticResource ToggleSwitch}"
                              VerticalAlignment="Top"
                              Margin="12,6,6,0"
                              ToolTip="Show all top-level windows (incl. tool/system); off = only taskbar apps"
                              Checked="Extended_Changed"
                              Unchecked="Extended_Changed" Height="18"/>

                    <TextBlock Grid.Column="2"
                               Text="Extended"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Top" Margin="18,25,12,0" Height="12"/>
                </Grid>

            </StackPanel>

            <!-- Buttons unten -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,1,0,0" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Padding="14,7" Margin="0,0,8,0"
                            Click="Cancel_Click"
                            MinWidth="90"
                            IsCancel="True"/>
                    <Button x:Name="AddButton" Content="Add"
                            Style="{StaticResource AccentButton}"
                            Padding="14,7"
                            Click="Add_Click"
                            IsDefault="True"
                            IsEnabled="False"
                            MinWidth="90"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>