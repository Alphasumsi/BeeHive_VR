<Window x:Class="BeeHiveVR.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BeeHiveVR.ViewModels"
        xmlns:m="clr-namespace:BeeHiveVR.Models"
        xmlns:views="clr-namespace:BeeHiveVR.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{Binding ProductName}"
        Icon="Assets/bee_icon_256.ico"
        Height="780" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgPrimary}"
        Foreground="#F2F2F2"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="1"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Background="{StaticResource BgPrimary}" x:Name="RootGrid">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
            <RowDefinition Height="*"/>
            <!-- Body -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
                <!-- TITLE BAR                                                         -->
                <!-- ================================================================ -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1" Height="36"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Logo: lädt Assets/logo.png falls vorhanden, sonst Fallback-Path -->
                    <Grid Width="20" Height="20" Margin="12,0,8,0" VerticalAlignment="Center">
                        <!-- Fallback (immer sichtbar, wird vom Image überdeckt wenn vorhanden) -->
                        <Border Background="{StaticResource AccentBgSolid}"
                                        CornerRadius="9">
                            <Path Data="M12 2 L20 7 V17 L12 22 L4 17 V7 Z M12 6 L17 9 V15 L12 18 L7 15 V9 Z"
                                          Stretch="Uniform" Fill="#1A1A1A" Margin="3"/>
                        </Border>
                        <!-- Logo-Bild (überdeckt den Fallback wenn die Datei existiert) -->
                        <Image x:Name="TitleBarLogo"
                                       Source="Assets\bee_icon_256.ico"
                                       Stretch="Uniform">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <Trigger Property="Source" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                    <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                               <!-- VR-Visible Master-Toggle -->
                               <Button Click="ToggleOverlaysVisible_Click"
                                    Style="{StaticResource IconButton}"
                                    Padding="0" Margin="0,4,12,4"
                                    Cursor="Hand"
                                    ToolTip="Toggle overlays in VR (global master switch)">
                                    <Border CornerRadius="10" Padding="10,4">
                                       <Border.Style>
                                          <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource SuccessBg}"/>
                                             <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OverlaysVisibleInVR}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource DangerBg}"/>
                                                    </DataTrigger>
                                              </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                       <StackPanel Orientation="Horizontal">
                                           <!-- Eye-Icon (offen wenn visible, durchgestrichen wenn hidden) -->
                                          <Path Width="13" Height="13" Stretch="Uniform"
                                                          VerticalAlignment="Center" StrokeThickness="2"
                                                        Fill="Transparent">
                                                <Path.Style>
                                                   <Style TargetType="Path">
                                                        <Setter Property="Stroke" Value="{StaticResource SuccessText}"/>
                                                     <Setter Property="Data"
                                                               Value="M2 12 C5 6 9 4 12 4 C15 4 19 6 22 12 C19 18 15 20 12 20 C9 20 5 18 2 12 Z M12 9 a3 3 0 1 1 0 6 a3 3 0 1 1 0 -6"/>
                                                     <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OverlaysVisibleInVR}" Value="False">
                                                                <Setter Property="Stroke" Value="{StaticResource DangerText}"/>
                                                                <Setter Property="Data"
                                                                    Value="M2 12 C5 6 9 4 12 4 C15 4 19 6 22 12 C19 18 15 20 12 20 C9 20 5 18 2 12 Z M3 3 L21 21"/>
                                                          </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Margin="6,0,0,0" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Visible"/>
                                            <Setter Property="Foreground" Value="{StaticResource SuccessText}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OverlaysVisibleInVR}" Value="False">
                                                    <Setter Property="Text" Value="Hidden"/>
                                                    <Setter Property="Foreground" Value="{StaticResource DangerText}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Active-Layout-Badge — sichtbar wenn ActiveLayout gesetzt -->
                    <Border CornerRadius="10" Padding="10,4" Margin="0,4,12,4"
                            Background="{StaticResource PinBg}"
                            BorderBrush="{StaticResource PinBorder}" BorderThickness="1"
                            VerticalAlignment="Center"
                            Visibility="{Binding ActiveLayout, Converter={StaticResource NullToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="11" Height="11" VerticalAlignment="Center"
                                  Data="M16 9V4 H8 V9 L5 12 V14 H19 V12 Z M11 14 V21 L12 22 L13 21 V14"
                                  Stretch="Uniform" Fill="{StaticResource PinText}"/>
                            <TextBlock Text="{Binding ActiveLayout.CarName}" Margin="6,0,0,0"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource PinText}"
                                       VerticalAlignment="Center"/>
                            <Button Width="16" Height="16" Margin="8,0,0,0"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding ClearActiveCommand}"
                                    ToolTip="Clear active layout">
                                <Path Data="M1,1 L9,9 M9,1 L1,9" Stroke="{StaticResource PinText}"
                                      StrokeThickness="1.5" Width="10" Height="10"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Button Click="Minimize_Click" Style="{StaticResource WindowButtonStyle}">
                                <Path Data="M0,5 H10" Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="1" Width="10" Height="10"/>
                            </Button>
                            <Button Click="MaxRestore_Click" Style="{StaticResource WindowButtonStyle}">
                                <Path Data="M0,0 H10 V10 H0 Z" Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="1" Width="10" Height="10" Fill="Transparent"/>
                            </Button>
                            <Button Click="Close_Click" Style="{StaticResource WindowCloseButtonStyle}">
                                <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{StaticResource TextPrimary}"
                                  StrokeThickness="1" Width="10" Height="10"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ================================================================ -->
                <!-- STATUS BAR (rechts neben Icon-Nav, oberhalb von Sidebar+Content)  -->
                <!-- ================================================================ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <!-- Platzhalter über Icon-Nav -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon-Nav-Bereich (Header-Hintergrund passt sich an Icon-Nav-Spalte an) -->
                    <Border Grid.Column="0" Background="{StaticResource BgTertiary}"
                        BorderBrush="{StaticResource BorderTertiary}"
                        BorderThickness="0,0,1,1"/>

                    <!-- Status-Inhalt -->
                    <Border Grid.Column="1" Background="{StaticResource BgPrimary}"
                        BorderBrush="{StaticResource BorderTertiary}"
                        BorderThickness="0,0,0,1" Height="36">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Section name -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Divider -->
                                <ColumnDefinition Width="*"/>
                                <!-- Live values -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Connected pill -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                   Text="{Binding ActiveSection, Converter={StaticResource SectionDisplayName}}"
                                   FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                            <Border Grid.Column="1" Width="1" Height="18" Margin="14,0"
                                Background="{StaticResource BorderTertiary}"/>

                            <!-- Car / Track / Session — nur sichtbar wenn Session aktiv -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,50,0"
                                    Visibility="{Binding HasActiveSession,
                                                 Converter={StaticResource BoolToVis}}">
                                <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Data="M5 17h2 M17 17h2 M3 17v-5l2-5h14l2 5v5 M7 17a2 2 0 1 0 0 0.01 M17 17a2 2 0 1 0 0 0.01"/>
                                <TextBlock Text="{Binding LiveCar}" Margin="6,0,12,0"
                                       Style="{StaticResource StatusBarLabel}"/>

                                <Border Width="1" Height="14" Background="{StaticResource BorderTertiary}"
                                    Margin="0,0,12,0"/>

                                <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Data="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 7 a3 3 0 1 1 0 6 a3 3 0 1 1 0 -6"/>
                                <TextBlock Text="{Binding LiveTrack}" Margin="6,0,12,0"
                                       Style="{StaticResource StatusBarLabel}"/>

                                <Border Width="1" Height="14" Background="{StaticResource BorderTertiary}"
                                    Margin="0,0,12,0"/>

                        <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Data="M12 3 a9 9 0 1 1 0 18 a9 9 0 1 1 0 -18 M12 7 V12 L15 14"/>
                        <TextBlock Text="{Binding LiveSession}" Margin="6,0,12,0"
                                       Style="{StaticResource StatusBarLabel}"/>

                        <Border Width="1" Height="14" Background="{StaticResource BorderTertiary}"
                                    Margin="0,0,12,0"/>

                        <!-- Location (Pin-Icon) -->
                        <Path Width="13" Height="13" Stretch="Uniform"
                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                  VerticalAlignment="Center"
                                  Data="M12 2 L4 12 L12 22 L20 12 Z"/>
                        <TextBlock Text="{Binding LiveLocation}" Margin="6,0,0,0"
                                       Style="{StaticResource StatusBarLabel}"/>
                    </StackPanel>

                    <!-- Connected / Disconnected Pill rechts -->
                            <Border Grid.Column="3" CornerRadius="10" Padding="10,4"
                                VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SuccessBg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                <Setter Property="Background" Value="{StaticResource DangerBg}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource SuccessDot}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Fill" Value="{StaticResource DangerDot}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Connected"/>
                                                <Setter Property="Foreground" Value="{StaticResource SuccessText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                        <Setter Property="Text" Value="Disconnected"/>
                                                        <Setter Property="Foreground" Value="{StaticResource DangerText}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ================================================================ -->
                <!-- BODY (Icon-Nav + Layout-Sidebar + Hauptbereich)                   -->
                <!-- ================================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Layout">
                                    <Setter Property="Width" Value="300"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ICON-NAV -->
                    <Border Grid.Column="0" Background="{StaticResource BgTertiary}"
                        BorderBrush="{StaticResource BorderTertiary}"
                        BorderThickness="0,0,1,0">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">

                                <!-- Main -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Menu, Mode=OneWay}"
                                          ToolTip="Menu"
                                          Click="NavMenu_Click">
                            <Path Data="M3 12 L12 3 L21 12 M5 10 V21 H19 V10"
                                      Stretch="Uniform" Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="2" Width="25" Height="25"/>
                                </RadioButton>

                                <!-- Layout (default aktiv) -->
                                <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Layout, Mode=OneWay}"
                                          ToolTip="VR-Layouts"
                                          Click="NavLayout_Click">
                                    <Path Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M3,14 H10 V21 H3 Z M14,14 H21 V21 H14 Z"
                                      Stretch="Uniform" Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="2" Width="25" Height="25"/>
                                </RadioButton>

                        <!-- TP — Trading Paints (Platzhalter)-->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Trading Paints, Mode=OneWay}"
                                          Visibility="{Binding ShowTradingPaints,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="Trading Paints"
                                          Click="NavTP_Click">
                            <!-- Pinsel-Icon -->
                            <Path Data="M3 21 L8 16 a3 3 0 0 1 4 0 a3 3 0 0 1 0 4 L7 21 Z M10 14 L19 5 a2 2 0 0 1 3 0 a2 2 0 0 1 0 3 L13 17 Z"
                                      Stretch="Uniform" Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="2" Fill="Transparent"
                                      Width="25" Height="25"/>
                        </RadioButton>

                        <!-- irDashies -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=irDashies, Mode=OneWay}"
                                          Visibility="{Binding ShowHtmlOverlays,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="irDashies"
                                          Click="NavHtml_Click">
                            <Path Data="M5 14 C5 8 9 4 13 4 C17 4 20 7 20 12 L20 15 C20 16 19 17 18 17 L8 17 L6 19 Z M6.5 11 L18 11"
                                      Stretch="Uniform" Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="2" Fill="Transparent"
                                      Width="25" Height="25"/>
                        </RadioButton>

                        <!-- Dashies — In-App-Config der irDashies-Overlays (STUB) -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Dashies, Mode=OneWay}"
                                          Visibility="{Binding ShowDashies,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="Dashies"
                                          Click="NavDashies_Click">
                            <!-- Schieberegler-Icon (Config) -->
                            <Path Data="M4 7 H14 M18 7 H20 M4 12 H8 M12 12 H20 M4 17 H16 M20 17 H20 M14 5 a2 2 0 1 1 0 4 a2 2 0 1 1 0 -4 M8 10 a2 2 0 1 1 0 4 a2 2 0 1 1 0 -4 M16 15 a2 2 0 1 1 0 4 a2 2 0 1 1 0 -4"
                                      Stretch="Uniform" Stroke="{StaticResource DevModeAccent}"
                                      StrokeThickness="2" Fill="Transparent"
                                      Width="25" Height="25"/>
                        </RadioButton>

                        <!-- Autostart (Platzhalter) -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Autostart, Mode=OneWay}"
                                          Visibility="{Binding ShowAutostart,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="Autostart"
                                          Click="NavAutostart_Click">
                            <Path Data="M13 2 L4 14 H11 L9 22 L20 10 H13 Z"
                                      Stretch="Uniform" Stroke="{StaticResource DevModeAccent}"
                                      StrokeThickness="2" Fill="Transparent"
                                      Width="25" Height="25"/>
                        </RadioButton>

                        <!-- Buttonbox (Platzhalter) -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Buttonbox, Mode=OneWay}"
                                          Visibility="{Binding ShowButtonbox,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="Buttonbox"
                                          Click="NavButtonbox_Click">
                            <Path Data="M3 5 H21 V19 H3 Z M7 10 h0.01 M12 10 h0.01 M17 10 h0.01 M7 15 h0.01 M12 15 h0.01 M17 15 h0.01"
                                      Stretch="Uniform" Stroke="{StaticResource DevModeAccent}"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Width="25" Height="25"/>
                        </RadioButton>
                    </StackPanel>
                            
                        <!-- Settings -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Settings, Mode=OneWay}"
                                          ToolTip="Settings"
                                          Click="NavSettings_Click">
                            <Grid>
                                <!-- Zahnrad (normal, Amber-Foreground vom Style) -->
                                <Path Stretch="Uniform" Stroke="{Binding Foreground,
                                              RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                          StrokeThickness="2" Fill="Transparent"
                                          Width="25" Height="25"
                                          Visibility="{Binding IsDevMode,
                                              Converter={StaticResource BoolToVis},
                                              ConverterParameter=Invert}"
                                          Data="M10 2 H14 V5 L17 6 L19 4 L21 6 L19 8 L20 11 H23 V13 H20 L19 16 L21 18 L19 20 L17 18 L14 19 V22 H10 V19 L7 18 L5 20 L3 18 L5 16 L4 13 H1 V11 H4 L5 8 L3 6 L5 4 L7 6 L10 5 Z M9 12 a3 3 0 1 1 6 0 a3 3 0 1 1 -6 0"/>
                                <!-- Zahnrad (Dev-Mode aktiv: Blau) -->
                                <Path Stretch="Uniform" Stroke="{StaticResource DevModeAccent}"
                                          StrokeThickness="2" Fill="Transparent"
                                          Width="25" Height="25"
                                          Visibility="{Binding IsDevMode,
                                              Converter={StaticResource BoolToVis}}"
                                          Data="M10 2 H14 V5 L17 6 L19 4 L21 6 L19 8 L20 11 H23 V13 H20 L19 16 L21 18 L19 20 L17 18 L14 19 V22 H10 V19 L7 18 L5 20 L3 18 L5 16 L4 13 H1 V11 H4 L5 8 L3 6 L5 4 L7 6 L10 5 Z M9 12 a3 3 0 1 1 6 0 a3 3 0 1 1 -6 0"/>
                            </Grid>
                        </RadioButton>

                        <!-- Debug -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Debug, Mode=OneWay}"
                                          Visibility="{Binding ShowDebug,
                                              Converter={StaticResource BoolToVis}}"
                                          ToolTip="Debug"
                                          Click="NavDebug_Click">
                            <Path Data="M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                                      Stretch="Uniform" Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="2" Width="25" Height="25"/>
                        </RadioButton>

                        <!-- Support -->
                        <RadioButton Style="{StaticResource IconNavButton}"
                                          GroupName="MainNav"
                                          IsChecked="{Binding ActiveSection,
                                              Converter={StaticResource EnumToBool},
                                              ConverterParameter=Support, Mode=OneWay}"
                                          ToolTip="Support"
                                          Click="NavSupport_Click">
                                    <Grid Width="25" Height="25">
                                        <Ellipse Stroke="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                          StrokeThickness="2"/>
                                        <TextBlock Text="?" FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding Foreground,
                                          RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </RadioButton>
                            </StackPanel>
                        </DockPanel>
                    </Border>

            <!-- LAYOUT-SIDEBAR — nur sichtbar wenn Layout-Section aktiv.
                 Zwei Varianten gestapelt: VR (Default) vs. Legacy (Dev-Toggle UseLegacyLayoutBar). -->
            <Grid Grid.Column="1"
                  Visibility="{Binding ActiveSection,
                      Converter={StaticResource StringEqualsToVis},
                      ConverterParameter=Layout}">
                <views:LayoutSidebar
                    Visibility="{Binding UseLegacyLayoutBar,
                        Converter={StaticResource BoolToVis}}"/>
                <views:VRLayoutSidebar
                    Visibility="{Binding UseLegacyLayoutBar,
                        Converter={StaticResource BoolToVis},
                        ConverterParameter=Invert}"/>
            </Grid>

            <!-- HAUPTBEREICH — Page-Switcher abhängig von ActiveSection -->
            <Grid Grid.Column="2">
                <views:MenuPage     Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Menu}"/>
                <views:LayoutPage   Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Layout}"/>
                <views:DebugPage    Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Debug}"/>
                <views:TPPage       Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Trading Paints}"/>
                <views:SettingsPage Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Settings}"/>
                <views:SupportPage  Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Support}"/>

                <views:DashiesPage  Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Dashies}"/>

                <!-- Platzhalter-Sektionen (Nav-Icons existieren, Inhalt kommt später) -->
                <views:HtmlOverlaysPage Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=irDashies}"/>
                <views:AutostartPage    Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Autostart}"/>
                <views:ButtonboxPage    Visibility="{Binding ActiveSection,
                                                Converter={StaticResource StringEqualsToVis},
                                                ConverterParameter=Buttonbox}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>