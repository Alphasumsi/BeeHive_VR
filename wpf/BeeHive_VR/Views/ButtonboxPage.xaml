<UserControl x:Class="BeeHiveVR.Views.ButtonboxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgPrimary}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Buttonbox"
                       FontSize="32" FontWeight="Light"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"/>
            <TextBlock Text="coming soon"
                       FontSize="14" Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextTertiary}"/>
        </StackPanel>
    </Grid>
</UserControl>
