                                        <TextBlock Grid.Column="0" Text="Minimal Status Badges" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="stylingOptions.statusBadges" Click="Toggle_Changed"/></Grid>

                                    <TextBlock Text="Flag Contour" Style="{StaticResource SectionHeader}"/>
