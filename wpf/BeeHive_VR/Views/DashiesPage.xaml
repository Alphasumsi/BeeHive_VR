                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="StdResetDisplay_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>
                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="StdSizeWidth" Width="80" Text="560" HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="StdSizeHeight" Width="80" Text="774" HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0" Padding="14,6" VerticalAlignment="Center" Cursor="Hand" Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0" Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- ===== OPTIONS TAB ===== -->
                                <StackPanel x:Name="StdOptionsTab" Visibility="Collapsed">
                                    <TextBlock Text="Driver Standings" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Drivers around player" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="driverStandings.buffer" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="1" Tag="1"/><ComboBoxItem Content="2" Tag="2"/><ComboBoxItem Content="3" Tag="3"/><ComboBoxItem Content="4" Tag="4"/><ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/><ComboBoxItem Content="7" Tag="7"/><ComboBoxItem Content="8" Tag="8"/><ComboBoxItem Content="9" Tag="9"/><ComboBoxItem Content="10" Tag="10"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Drivers in other classes" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=StdNonClass, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                            <Slider x:Name="StdNonClass" Minimum="0" Maximum="63" Value="3" VerticalAlignment="Center" Tag="driverStandings.numNonClassDrivers" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Min drivers in player's class" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=StdMinClass, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                            <Slider x:Name="StdMinClass" Minimum="1" Maximum="63" Value="1" VerticalAlignment="Center" Tag="driverStandings.minPlayerClassDrivers" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Top drivers always shown" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=StdTopDrivers, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                            <Slider x:Name="StdTopDrivers" Minimum="0" Maximum="63" Value="0" VerticalAlignment="Center" Tag="driverStandings.numTopDrivers" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Top driver divider" Style="{StaticResource RowLabel}"/>
