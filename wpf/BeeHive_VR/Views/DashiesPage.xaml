<UserControl x:Class="BeeHiveVR.Views.DashiesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="640"
             Background="{StaticResource BgPrimary}">

    <!-- STUB (Häppchen „UI zuerst"): Gerüst, keine echte Funktion.
         Strip-Regel: alles raus was BeeHive VR schon macht (Opacity, Visibility,
         Position). Drin nur Widget-Inhalt/Aussehen. Toggle-Switches,
         einklappbare + eingerückte Sub-Sektionen, Display-Order per Drag.
         Final wird das Panel durch die adaptierte irdashies-UI ersetzt. -->

    <UserControl.Resources>
        <!-- Tab-Optik für RadioButtons (Unterstrich beim aktiven) -->
        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Padding="2,4" BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="BorderBrush"
                                        Value="{StaticResource AccentText}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style x:Key="RowHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <!-- Sektions-Überschrift (Trace, Bar, …) — etwas größer + Akzentfarbe -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentText}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <!-- Eingerückte Sub-Gruppe mit Guide-Linie links (wie Vorlage).
             Rechter Innenabstand rückt auch die (rechtsbündigen) Toggles
             nach links; bei tieferer Verschachtelung summiert sich das. -->
        <Style x:Key="SubGroup" TargetType="Border">
            <Setter Property="Margin" Value="7,2,0,6"/>
            <Setter Property="Padding" Value="14,2,18,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>

        <DataTemplate x:Key="DisplayRowTemplate">
            <Border CornerRadius="4" Margin="0,2" Padding="8,6" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
                        <Style.Triggers>
                            <!-- Während des Ziehens: ausgegraut + Akzent-Rahmen (Vorschau) -->
                            <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentText}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Tag="drag" Text="&#x2630;"
                               Foreground="{StaticResource TextTertiary}"
                               FontSize="13" Cursor="SizeAll"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Drag to reorder"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               Style="{StaticResource RowLabel}"/>
                    <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding Enabled}" VerticalAlignment="Center"
                              Click="DisplayToggle_Changed"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="0,0,0,1" Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Border Padding="14,8" BorderBrush="{StaticResource AccentText}"
                            BorderThickness="0,0,0,2">
                        <TextBlock Text="Dashies" FontSize="15" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body: Sidebar | Settings-Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Sidebar: verfügbare Overlays (alphabetisch) ===== -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource BgSecondary}"
                    Padding="10,10" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Overlays"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextTertiary}"
                               Margin="2,0,0,8"/>
                    <ListBox x:Name="OverlayList"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource TextPrimary}"
                             SelectionChanged="OverlayList_SelectionChanged">
                        <ListBoxItem Content="Blind Spot Monitor"/>
                        <ListBoxItem Content="Fuel Calculator"/>
                        <ListBoxItem Content="Input"/>
                        <ListBoxItem Content="Pitlane Helper"/>
                        <ListBoxItem Content="Relative"/>
                        <ListBoxItem Content="Standings"/>
                        <ListBoxItem Content="Track Map"/>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ===== Rechter Bereich ===== -->
            <Border Grid.Column="1" BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource BgSecondary}">
                <Grid>

                    <!-- Generischer Platzhalter (alle Overlays außer Input) -->
                    <StackPanel x:Name="GenericPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="PanelTitle" Text="Select an overlay"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="The settings panel for the selected overlay will appear here."
                                   FontSize="12" Foreground="{StaticResource TextTertiary}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="360" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Input-Settings-Panel (adaptierter Mock-Stub) -->
                    <DockPanel x:Name="InputPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Input Traces" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Configure the input traces display for throttle, brake, clutch, steering and gear."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <!-- Tabs (Visibility raus — macht BeeHive VR) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="TabDisplay" GroupName="InputTabs"
                                             Content="Display" Style="{StaticResource TabRadio}"
                                             Checked="InputTab_Checked"/>
                                <RadioButton x:Name="TabOptions" GroupName="InputTabs"
                                             Content="Options" Style="{StaticResource TabRadio}"
                                             Checked="InputTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}"
                                    Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- DISPLAY TAB: Display Order (drag-verschiebbar) + Format -->
                                <StackPanel x:Name="DisplayTab">
                                    <TextBlock Text="Display Order" Style="{StaticResource SectionHeader}"
                                               Margin="0,4,0,6"/>
                                    <TextBlock Text="Drag the handle to reorder. Toggle to show/hide each element."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="DisplayOrderList"
                                                  AllowDrop="True"
                                                  ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                  PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                  DragOver="DisplayOrderList_DragOver"
                                                  Drop="DisplayOrderList_Drop"/>
                                    <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="ResetDisplayOrder_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>

                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here. You can also type values manually."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="SizeWidth" Width="80" Text="420"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="SizeHeight" Width="80" Text="240"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0"
                                                Padding="14,6" VerticalAlignment="Center" Cursor="Hand"
                                                Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- OPTIONS TAB. Jedes Control trägt seinen JSON-Pfad als Tag;
                                     generische Handler patchen die Input-Config + Live-Reload.
                                     BeeHive-VR-Sachen (Opacity/Visibility) bewusst raus. -->
                                <StackPanel x:Name="OptionsTab" Visibility="Collapsed">
                                    <Grid Margin="0,12,0,4">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Use Raw Inputs" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Direct pedal telemetry without iRacing assists (auto-clutch, anti-stall)."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  Tag="useRawValues" Click="Toggle_Changed"/>
                                    </Grid>

                                    <!-- Trace -->
                                    <TextBlock Text="Trace" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Trace Display" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="TraceEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="True" VerticalAlignment="Center" Tag="trace.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}"
                                            Visibility="{Binding IsChecked, ElementName=TraceEnable, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Clutch Trace" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="trace.includeClutch" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Throttle Trace" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="trace.includeThrottle" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Brake Trace" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="trace.includeBrake" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show ABS" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="trace.includeAbs" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Steering Trace" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="trace.includeSteer" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Stroke Width" Style="{StaticResource RowLabel}"/>
                                                <DockPanel Grid.Column="1">
                                                    <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right"
                                                               VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                        <TextBlock.Text><MultiBinding Converter="{StaticResource SliderPercent}">
                                                            <Binding ElementName="SldStroke" Path="Value"/><Binding ElementName="SldStroke" Path="Minimum"/><Binding ElementName="SldStroke" Path="Maximum"/>
                                                        </MultiBinding></TextBlock.Text></TextBlock>
                                                    <Slider x:Name="SldStroke" Minimum="0" Maximum="10" Value="3" VerticalAlignment="Center" Tag="trace.strokeWidth" ValueChanged="Slider_Changed"/>
                                                </DockPanel></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Max Samples" Style="{StaticResource RowLabel}"/>
                                                <DockPanel Grid.Column="1">
                                                    <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right"
                                                               VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                        <TextBlock.Text><MultiBinding Converter="{StaticResource SliderPercent}">
                                                            <Binding ElementName="SldMaxSamples" Path="Value"/><Binding ElementName="SldMaxSamples" Path="Minimum"/><Binding ElementName="SldMaxSamples" Path="Maximum"/>
                                                        </MultiBinding></TextBlock.Text></TextBlock>
                                                    <Slider x:Name="SldMaxSamples" Minimum="40" Maximum="1000" Value="40" VerticalAlignment="Center" Tag="trace.maxSamples" ValueChanged="Slider_Changed"/>
                                                </DockPanel></Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Bar -->
                                    <TextBlock Text="Bar" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Bar Display" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="BarEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="True" VerticalAlignment="Center" Tag="bar.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}"
                                            Visibility="{Binding IsChecked, ElementName=BarEnable, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Clutch Bar" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="bar.includeClutch" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Throttle Bar" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="bar.includeThrottle" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Brake Bar" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="bar.includeBrake" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show ABS Indicator" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="bar.includeAbs" Click="Toggle_Changed"/></Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ABS Indicator -->
                                    <TextBlock Text="ABS Indicator" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable ABS Indicator" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="abs.enabled" Click="Toggle_Changed"/></Grid>

                                    <!-- Steer -->
                                    <TextBlock Text="Steer" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Steer Display" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="SteerEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="True" VerticalAlignment="Center" Tag="steer.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}"
                                            Visibility="{Binding IsChecked, ElementName=SteerEnable, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Wheel Style" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="steer.config.style" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Default" Tag="default"/><ComboBoxItem Content="Formula" Tag="formula"/>
                                                    <ComboBoxItem Content="LMP" Tag="lmp"/><ComboBoxItem Content="NASCAR" Tag="nascar"/>
                                                    <ComboBoxItem Content="U-Shape" Tag="ushape"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Wheel Color" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="steer.config.color" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Light" Tag="light"/><ComboBoxItem Content="Dark" Tag="dark"/></ComboBox></Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Gear -->
                                    <TextBlock Text="Gear" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Gear Display" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="GearEnable" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="True" VerticalAlignment="Center" Tag="gear.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}"
                                            Visibility="{Binding IsChecked, ElementName=GearEnable, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Gear Display Scale" Style="{StaticResource RowLabel}"/>
                                                <DockPanel Grid.Column="1">
                                                    <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right"
                                                               VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                        <TextBlock.Text><MultiBinding Converter="{StaticResource SliderPercent}">
                                                            <Binding ElementName="SldGearSize" Path="Value"/><Binding ElementName="SldGearSize" Path="Minimum"/><Binding ElementName="SldGearSize" Path="Maximum"/>
                                                        </MultiBinding></TextBlock.Text></TextBlock>
                                                    <Slider x:Name="SldGearSize" Minimum="50" Maximum="150" Value="100" VerticalAlignment="Center" Tag="gear.size" ValueChanged="Slider_Changed"/>
                                                </DockPanel></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Speed" Style="{StaticResource RowLabel}"/>
                                                <CheckBox x:Name="ShowSpeed" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                          IsChecked="True" VerticalAlignment="Center" Tag="gear.showspeed" Click="Toggle_Changed"/></Grid>
                                            <Border Style="{StaticResource SubGroup}"
                                                    Visibility="{Binding IsChecked, ElementName=ShowSpeed, Converter={StaticResource BoolToVis}}">
                                                <StackPanel>
                                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Speed Unit" Style="{StaticResource RowLabel}"/>
                                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="gear.unit" SelectionChanged="Combo_Changed">
                                                            <ComboBoxItem Content="Auto" Tag="auto"/><ComboBoxItem Content="MPH" Tag="mph"/>
                                                            <ComboBoxItem Content="KM/H" Tag="km/h"/></ComboBox></Grid>
                                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Show Speed Unit Label" Style="{StaticResource RowLabel}"/>
                                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="gear.showspeedunit" Click="Toggle_Changed"/></Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Relative-Settings-Panel (adaptiert; Opacity/Visibility raus) ===== -->
                    <DockPanel x:Name="RelativePanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Relative" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Configure the relative timing display: columns, header/footer bars and styling."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="RelTabDisplay" GroupName="RelTabs"
                                             Content="Display" Style="{StaticResource TabRadio}" Checked="RelTab_Checked"/>
                                <RadioButton x:Name="RelTabOptions" GroupName="RelTabs"
                                             Content="Options" Style="{StaticResource TabRadio}" Checked="RelTab_Checked"/>
                                <RadioButton x:Name="RelTabHeader" GroupName="RelTabs"
                                             Content="Header" Style="{StaticResource TabRadio}" Checked="RelTab_Checked"/>
                                <RadioButton x:Name="RelTabFooter" GroupName="RelTabs"
                                             Content="Footer" Style="{StaticResource TabRadio}" Checked="RelTab_Checked"/>
                                <RadioButton x:Name="RelTabStyling" GroupName="RelTabs"
                                             Content="Styling" Style="{StaticResource TabRadio}" Checked="RelTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- ===== DISPLAY TAB ===== -->
                                <StackPanel x:Name="RelDisplayTab">
                                    <TextBlock Text="Display Order" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <TextBlock Text="Drag the handle to reorder. Toggle to show/hide each column."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="RelDisplayList" AllowDrop="True"
                                                  ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                  PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                  DragOver="DisplayOrderList_DragOver"
                                                  Drop="DisplayOrderList_Drop"/>
                                    <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="RelResetDisplay_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>

                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="RelSizeWidth" Width="80" Text="402"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="RelSizeHeight" Width="80" Text="300"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0"
                                                Padding="14,6" VerticalAlignment="Center" Cursor="Hand"
                                                Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- ===== OPTIONS TAB ===== -->
                                <StackPanel x:Name="RelOptionsTab" Visibility="Collapsed">
                                    <!-- Driver Standings -->
                                    <TextBlock Text="Driver Standings" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Drivers to show around player" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="buffer" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="1" Tag="1"/><ComboBoxItem Content="2" Tag="2"/><ComboBoxItem Content="3" Tag="3"/>
                                            <ComboBoxItem Content="4" Tag="4"/><ComboBoxItem Content="5" Tag="5"/><ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/><ComboBoxItem Content="8" Tag="8"/><ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Use Live Position Standings" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Live telemetry positions — updates continuously, not only at start/finish."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="useLivePosition" Click="Toggle_Changed"/></Grid>

                                    <!-- Relative Time -->
                                    <TextBlock Text="Relative Time" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Decimal places" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="delta.precision" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="0" Tag="0"/><ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/><ComboBoxItem Content="3" Tag="3"/></ComboBox></Grid>

                                    <!-- Title Bar -->
                                    <TextBlock Text="Title Bar" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Title Bar" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelTitleBar" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="titleBar.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelTitleBar, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Show Progress Bar" Style="{StaticResource RowLabel}"/>
                                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="titleBar.progressBar.enabled" Click="Toggle_Changed"/></Grid>
                                    </Border>

                                    <!-- Driver Name -->
                                    <TextBlock Text="Driver Name" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Driver Name" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelDriverName" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="driverName.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelDriverName, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name Format" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="driverName.nameFormat" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="First Middle Last" Tag="name-middlename-surname"/>
                                                    <ComboBoxItem Content="First M. Last" Tag="name-m.-surname"/>
                                                    <ComboBoxItem Content="First Last" Tag="name-surname"/>
                                                    <ComboBoxItem Content="F. Last" Tag="n.-surname"/>
                                                    <ComboBoxItem Content="Last F." Tag="surname-n."/>
                                                    <ComboBoxItem Content="Last" Tag="surname"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Remove Numbers From Names" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="driverName.removeNumbersFromName" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Status Badges" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="driverName.showStatusBadges" Click="Toggle_Changed"/></Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Pit Status -->
                                    <TextBlock Text="Pit Status" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Pit Status" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelPitStatus" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="pitStatus.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelPitStatus, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Show Pit Time" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="pitStatus.showPitTime" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Pit Lap Display" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="pitStatus.pitLapDisplayMode" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Last pit lap" Tag="lastPitLap"/>
                                                    <ComboBoxItem Content="Laps since last pit" Tag="lapsSinceLastPit"/></ComboBox></Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Car Manufacturer -->
                                    <TextBlock Text="Car Manufacturer" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Car Manufacturer" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelCarMfg" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="carManufacturer.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelCarMfg, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Hide If Single Make" Style="{StaticResource RowLabel}"/>
                                            <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="carManufacturer.hideIfSingleMake" Click="Toggle_Changed"/></Grid>
                                    </Border>

                                    <!-- Driver Badge -->
                                    <TextBlock Text="Driver Badge" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Driver Badge" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelBadge" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="badge.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelBadge, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Badge Format" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="4" VerticalAlignment="Center" Tag="badge.badgeFormat" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="License + full iR (combo)" Tag="license-color-fullrating-combo"/>
                                                <ComboBoxItem Content="Full iR color, no license" Tag="fullrating-color-no-license"/>
                                                <ComboBoxItem Content="iR color, no license" Tag="rating-color-no-license"/>
                                                <ComboBoxItem Content="License color, full iR b/w" Tag="license-color-fullrating-bw"/>
                                                <ComboBoxItem Content="License color, iR b/w" Tag="license-color-rating-bw"/>
                                                <ComboBoxItem Content="iR only color, iR b/w" Tag="rating-only-color-rating-bw"/>
                                                <ComboBoxItem Content="License color, iR b/w, no license" Tag="license-color-rating-bw-no-license"/>
                                                <ComboBoxItem Content="License b/w, iR b/w" Tag="license-bw-rating-bw"/>
                                                <ComboBoxItem Content="iR only b/w" Tag="rating-only-bw-rating-bw"/>
                                                <ComboBoxItem Content="License b/w, iR b/w, no license" Tag="license-bw-rating-bw-no-license"/>
                                                <ComboBoxItem Content="iR b/w, no license" Tag="rating-bw-no-license"/>
                                                <ComboBoxItem Content="Full iR b/w, no license" Tag="fullrating-bw-no-license"/></ComboBox></Grid>
                                    </Border>

                                    <!-- Best Time -->
                                    <TextBlock Text="Best Time" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Best Time" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelFastest" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="fastestTime.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelFastest, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Time Format" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="fastestTime.timeFormat" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="1:42.123" Tag="full"/><ComboBoxItem Content="1:42.1" Tag="mixed"/>
                                                <ComboBoxItem Content="1:42" Tag="minutes"/><ComboBoxItem Content="42.123" Tag="seconds-full"/>
                                                <ComboBoxItem Content="42.1" Tag="seconds-mixed"/><ComboBoxItem Content="42" Tag="seconds"/></ComboBox></Grid>
                                    </Border>

                                    <!-- Last Time -->
                                    <TextBlock Text="Last Time" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Last Time" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelLast" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="lastTime.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelLast, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Time Format" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="lastTime.timeFormat" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="1:42.123" Tag="full"/><ComboBoxItem Content="1:42.1" Tag="mixed"/>
                                                <ComboBoxItem Content="1:42" Tag="minutes"/><ComboBoxItem Content="42.123" Tag="seconds-full"/>
                                                <ComboBoxItem Content="42.1" Tag="seconds-mixed"/><ComboBoxItem Content="42" Tag="seconds"/></ComboBox></Grid>
                                    </Border>

                                    <!-- Lap Delta -->
                                    <TextBlock Text="Lap Delta" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Lap Delta" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelLapDelta" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="lapTimeDeltas.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelLapDelta, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Number of Laps to Show" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="lapTimeDeltas.numLaps" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="1" Tag="1"/><ComboBoxItem Content="2" Tag="2"/><ComboBoxItem Content="3" Tag="3"/>
                                                <ComboBoxItem Content="4" Tag="4"/><ComboBoxItem Content="5" Tag="5"/></ComboBox></Grid>
                                    </Border>

                                    <!-- Driven Laps -->
                                    <TextBlock Text="Driven Laps" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Show Driven Laps" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Laps driven since the last pit stop (or since session start)."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <CheckBox x:Name="RelDrivenLaps" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="drivenLaps.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelDrivenLaps, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="190"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Count" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="drivenLaps.mode" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="Since last pit" Tag="sinceLastPit"/>
                                                <ComboBoxItem Content="Since Session start" Tag="sinceStart"/>
                                                <ComboBoxItem Content="Both" Tag="both"/></ComboBox></Grid>
                                    </Border>
                                </StackPanel>

                                <!-- ===== HEADER TAB ===== -->
                                <StackPanel x:Name="RelHeaderTab" Visibility="Collapsed">
                                    <Grid Margin="0,8,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Header Bar" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelHeaderBar" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="headerBar.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelHeaderBar, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Items" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                            <TextBlock Text="Drag to reorder. Toggle each item on/off."
                                                       Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                            <ItemsControl x:Name="RelHeaderList" Tag="headerBar" AllowDrop="True"
                                                          ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                          PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                          PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                          DragOver="DisplayOrderList_DragOver"
                                                          Drop="DisplayOrderList_Drop"/>
                                            <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                                    Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                                    Click="RelResetHeader_Click"/>

                                            <TextBlock Text="Item Options" Style="{StaticResource SectionHeader}"/>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Air Temp Unit" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.airTemperature.unit" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="&#xB0;C" Tag="Metric"/><ComboBoxItem Content="&#xB0;F" Tag="Imperial"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Track Temp Unit" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.trackTemperature.unit" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="&#xB0;C" Tag="Metric"/><ComboBoxItem Content="&#xB0;F" Tag="Imperial"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Mode" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.sessionTime.mode" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Remaining" Tag="Remaining"/><ComboBoxItem Content="Elapsed" Tag="Elapsed"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Format" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.sessionTime.totalFormat" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="2:34" Tag="minimal"/><ComboBoxItem Content="00:12:34" Tag="hh:mm"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Labels" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.sessionTime.labelStyle" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Minimal" Tag="minimal"/><ComboBoxItem Content="Short" Tag="short"/>
                                                    <ComboBoxItem Content="None" Tag="none"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Laps Mode" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="headerBar.sessionLaps.mode" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Elapsed" Tag="Elapsed"/><ComboBoxItem Content="Remaining" Tag="Remaining"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Wind Speed Position" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="1" VerticalAlignment="Center" Tag="headerBar.wind.speedPosition" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Left" Tag="left"/><ComboBoxItem Content="Right" Tag="right"/></ComboBox></Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== FOOTER TAB ===== -->
                                <StackPanel x:Name="RelFooterTab" Visibility="Collapsed">
                                    <Grid Margin="0,8,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Footer Bar" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="RelFooterBar" Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="footerBar.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=RelFooterBar, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Items" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                            <TextBlock Text="Drag to reorder. Toggle each item on/off."
                                                       Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                            <ItemsControl x:Name="RelFooterList" Tag="footerBar" AllowDrop="True"
                                                          ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                          PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                          PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                          DragOver="DisplayOrderList_DragOver"
                                                          Drop="DisplayOrderList_Drop"/>
                                            <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                                    Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                                    Click="RelResetFooter_Click"/>

                                            <TextBlock Text="Item Options" Style="{StaticResource SectionHeader}"/>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Air Temp Unit" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.airTemperature.unit" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="&#xB0;C" Tag="Metric"/><ComboBoxItem Content="&#xB0;F" Tag="Imperial"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Track Temp Unit" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.trackTemperature.unit" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="&#xB0;C" Tag="Metric"/><ComboBoxItem Content="&#xB0;F" Tag="Imperial"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Mode" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.sessionTime.mode" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Remaining" Tag="Remaining"/><ComboBoxItem Content="Elapsed" Tag="Elapsed"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Format" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.sessionTime.totalFormat" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="2:34" Tag="minimal"/><ComboBoxItem Content="00:12:34" Tag="hh:mm"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Time Labels" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.sessionTime.labelStyle" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Minimal" Tag="minimal"/><ComboBoxItem Content="Short" Tag="short"/>
                                                    <ComboBoxItem Content="None" Tag="none"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Session Laps Mode" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="footerBar.sessionLaps.mode" SelectionChanged="Combo_Changed">
