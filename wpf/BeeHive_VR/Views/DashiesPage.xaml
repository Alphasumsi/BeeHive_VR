                                                <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                    <TextBlock.Text><Binding ElementName="SldBorderWidth" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="px"/></TextBlock.Text></TextBlock>
                                                <Slider x:Name="SldBorderWidth" Minimum="1" Maximum="10" Value="5" VerticalAlignment="Center" Tag="stylingOptions.flagContour.borderWidth" ValueChanged="Slider_Changed"/>
                                            </DockPanel></Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Track-Map-Settings-Panel (adaptiert; Visibility/Player-Icon raus) ===== -->
                    <DockPanel x:Name="TrackMapPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Track Map" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Configure the track map: track line, driver markers and styling."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="MapTabTrack" GroupName="MapTabs"
                                             Content="Track" Style="{StaticResource TabRadio}" Checked="MapTab_Checked"/>
                                <RadioButton x:Name="MapTabDrivers" GroupName="MapTabs"
                                             Content="Drivers" Style="{StaticResource TabRadio}" Checked="MapTab_Checked"/>
                                <RadioButton x:Name="MapTabStyling" GroupName="MapTabs"
                                             Content="Styling" Style="{StaticResource TabRadio}" Checked="MapTab_Checked"/>
                                <RadioButton x:Name="MapTabFormat" GroupName="MapTabs"
                                             Content="Format" Style="{StaticResource TabRadio}" Checked="MapTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- ===== TRACK TAB ===== -->
                                <StackPanel x:Name="MapTrackTab">
                                    <TextBlock Text="Track" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Track Line Width" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                <TextBlock.Text><Binding ElementName="MapTrackLine" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="px"/></TextBlock.Text></TextBlock>
                                            <Slider x:Name="MapTrackLine" Minimum="5" Maximum="40" Value="20" VerticalAlignment="Center" Tag="trackLineWidth" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Track Outline Width" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                <TextBlock.Text><Binding ElementName="MapTrackOutline" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="px"/></TextBlock.Text></TextBlock>
                                            <Slider x:Name="MapTrackOutline" Minimum="10" Maximum="80" Value="40" VerticalAlignment="Center" Tag="trackOutlineWidth" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Invert Track Colors" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="invertTrackColors" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Sector Colors" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Color sectors by session performance (thresholds in Sector Delta)."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="sectorColoring.enabled" Click="Toggle_Changed"/></Grid>

                                    <TextBlock Text="Turn Labels" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Enable Turn Labels" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="MapTurnLabels" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="turnLabels.enabled" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=MapTurnLabels, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Label Type" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="2" VerticalAlignment="Center" Tag="turnLabels.labelType" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Numbers" Tag="numbers"/><ComboBoxItem Content="Names" Tag="names"/>
                                                    <ComboBoxItem Content="Both" Tag="both"/></ComboBox></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="High Contrast Labels" Style="{StaticResource RowLabel}"/>
                                                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="turnLabels.highContrast" Click="Toggle_Changed"/></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Relative Label Size" Style="{StaticResource RowLabel}"/>
                                                <DockPanel Grid.Column="1">
                                                    <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                        <TextBlock.Text><Binding ElementName="MapLabelSize" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="%"/></TextBlock.Text></TextBlock>
                                                    <Slider x:Name="MapLabelSize" Minimum="50" Maximum="300" Value="100" VerticalAlignment="Center" Tag="turnLabels.labelFontSize" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== DRIVERS TAB ===== -->
                                <StackPanel x:Name="MapDriversTab" Visibility="Collapsed">
                                    <TextBlock Text="Driver Circles" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Car Numbers" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="MapShowCarNumbers" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="showCarNumbers" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=MapShowCarNumbers, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Display Mode" Style="{StaticResource RowLabel}"/>
                                            <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="displayMode" SelectionChanged="Combo_Changed">
                                                <ComboBoxItem Content="Car Number" Tag="carNumber"/>
                                                <ComboBoxItem Content="Session Position" Tag="sessionPosition"/>
                                                <ComboBoxItem Content="Live Position" Tag="livePosition"/></ComboBox></Grid>
                                    </Border>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Driver Circle Size" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                <TextBlock.Text><Binding ElementName="MapDriverCircle" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="px"/></TextBlock.Text></TextBlock>
                                            <Slider x:Name="MapDriverCircle" Minimum="10" Maximum="80" Value="40" VerticalAlignment="Center" Tag="driverCircleSize" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Player Circle Size" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                <TextBlock.Text><Binding ElementName="MapPlayerCircle" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="px"/></TextBlock.Text></TextBlock>
                                            <Slider x:Name="MapPlayerCircle" Minimum="10" Maximum="100" Value="40" VerticalAlignment="Center" Tag="playerCircleSize" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Relative Font Size" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}">
                                                <TextBlock.Text><Binding ElementName="MapFontSize" Path="Value" Converter="{StaticResource SliderUnit}" ConverterParameter="%"/></TextBlock.Text></TextBlock>
                                            <Slider x:Name="MapFontSize" Minimum="50" Maximum="150" Value="100" VerticalAlignment="Center" Tag="trackmapFontSize" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Use Highlight Color for Player" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="useHighlightColor" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Use Inverted Color for Leader" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="invertLeaderColor" Click="Toggle_Changed"/></Grid>
                                </StackPanel>

                                <!-- ===== STYLING TAB ===== -->
                                <StackPanel x:Name="MapStylingTab" Visibility="Collapsed">
                                    <TextBlock Text="Minimal Styling" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Minimal Track" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Remove the drop shadow from the track."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="styling.isMinimalTrack" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Minimal Car Markers" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Remove the drop shadow from the car markers."
                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="styling.isMinimalCar" Click="Toggle_Changed"/></Grid>
                                </StackPanel>

                                <!-- ===== FORMAT TAB ===== -->
                                <StackPanel x:Name="MapFormatTab" Visibility="Collapsed">
                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="MapSizeWidth" Width="80" Text="407"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="MapSizeHeight" Width="80" Text="227"
                                                 HorizontalContentAlignment="Center"
                                                 LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0"
                                                Padding="14,6" VerticalAlignment="Center" Cursor="Hand"
                                                Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="ResetFormat_Click"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Standings-Settings-Panel (adaptiert; Opacity/Visibility raus) ===== -->
                    <DockPanel x:Name="StandingsPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Standings" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Configure the standings table: columns, driver counts, header/footer bars and styling."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="StdTabDisplay" GroupName="StdTabs" Content="Display" Style="{StaticResource TabRadio}" Checked="StdTab_Checked"/>
                                <RadioButton x:Name="StdTabOptions" GroupName="StdTabs" Content="Options" Style="{StaticResource TabRadio}" Checked="StdTab_Checked"/>
                                <RadioButton x:Name="StdTabHeader" GroupName="StdTabs" Content="Header" Style="{StaticResource TabRadio}" Checked="StdTab_Checked"/>
                                <RadioButton x:Name="StdTabFooter" GroupName="StdTabs" Content="Footer" Style="{StaticResource TabRadio}" Checked="StdTab_Checked"/>
                                <RadioButton x:Name="StdTabStyling" GroupName="StdTabs" Content="Styling" Style="{StaticResource TabRadio}" Checked="StdTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

