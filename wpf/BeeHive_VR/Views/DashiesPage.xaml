                                <!-- ===== STYLING TAB ===== -->
                                <StackPanel x:Name="StdStylingTab" Visibility="Collapsed">
                                    <TextBlock Text="Class Header" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Class Name Background" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="classHeaderStyle.className.colorBackground" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Class Info Background" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="classHeaderStyle.classInfo.colorBackground" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Bottom Border" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="classHeaderStyle.classDivider.bottomBorder" Click="Toggle_Changed"/></Grid>

                                    <TextBlock Text="Driver Position" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Position Background" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="stylingOptions.driverPosition.background" Click="Toggle_Changed"/></Grid>

                                    <TextBlock Text="Car Number" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Number Background" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="stylingOptions.driverNumber.background" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Number Left Border" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="stylingOptions.driverNumber.border" Click="Toggle_Changed"/></Grid>

                                    <TextBlock Text="Badges" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Minimal License Badge" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="stylingOptions.badge" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Minimal Status Badges" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="stylingOptions.statusBadges" Click="Toggle_Changed"/></Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Fuel-Calculator-Settings-Panel (adaptiert; Layout-Editor/Opacity/Visibility raus) ===== -->
                    <DockPanel x:Name="FuelPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Fuel Calculator" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Configure the fuel calculator: which sections are shown and the calculation options."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="FuelTabDisplay" GroupName="FuelTabs" Content="Display" Style="{StaticResource TabRadio}" Checked="FuelTab_Checked"/>
                                <RadioButton x:Name="FuelTabOptions" GroupName="FuelTabs" Content="Options" Style="{StaticResource TabRadio}" Checked="FuelTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- ===== DISPLAY TAB (Sektionen-Reorder über layoutTree) ===== -->
                                <StackPanel x:Name="FuelDisplayTab">
                                    <TextBlock Text="Display Order" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <TextBlock Text="Drag the handle to reorder. Toggle to show/hide each section (vertical stack)."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="FuelDisplayList" Tag="@fuelLayout" AllowDrop="True"
                                                  ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                  PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                  DragOver="DisplayOrderList_DragOver" Drop="DisplayOrderList_Drop"/>
                                    <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="FuelResetDisplay_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>
                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="FuelSizeWidth" Width="80" Text="300" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="FuelSizeHeight" Width="80" Text="220" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0" Padding="14,6" VerticalAlignment="Center" Cursor="Hand" Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0" Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- ===== OPTIONS TAB (nur Werte, die die gezeigten Sektionen betreffen) ===== -->
                                <StackPanel x:Name="FuelOptionsTab" Visibility="Collapsed">
                                    <TextBlock Text="General" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Fuel Units" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="fuelUnits" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="Litres (L)" Tag="L"/><ComboBoxItem Content="Gallons (gal)" Tag="gal"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Fuel Required Mode" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="fuelRequiredMode" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="To Finish" Tag="toFinish"/><ComboBoxItem Content="To Add" Tag="toAdd"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Economy Predict" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="economyPredictMode" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="Live" Tag="live"/><ComboBoxItem Content="End of Lap" Tag="endOfLap"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Average Laps" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelAvgLaps, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                            <Slider x:Name="FuelAvgLaps" Minimum="1" Maximum="50" Value="5" VerticalAlignment="Center" Tag="avgLapsCount" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Safety Margin" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Extra fuel added to the &quot;To Finish&quot; calculation."
                                                       Style="{StaticResource RowHint}" MaxWidth="360" HorizontalAlignment="Left"/></StackPanel>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelSafety, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                            <Slider x:Name="FuelSafety" Minimum="0" Maximum="50" Value="5" VerticalAlignment="Center" Tag="safetyMargin" ValueChanged="Slider_Changed"/></DockPanel></Grid>

                                    <!-- Fuel Status Alerts -->
                                    <TextBlock Text="Fuel Status Alerts" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Border Color" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="showFuelStatusBorder" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Green Threshold" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelGreen, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=%}"/>
                                            <Slider x:Name="FuelGreen" Minimum="0" Maximum="100" Value="60" VerticalAlignment="Center" Tag="fuelStatusThresholds.green" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Amber Threshold" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelAmber, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=%}"/>
                                            <Slider x:Name="FuelAmber" Minimum="0" Maximum="100" Value="30" VerticalAlignment="Center" Tag="fuelStatusThresholds.amber" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Red Threshold" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelRed, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=%}"/>
                                            <Slider x:Name="FuelRed" Minimum="0" Maximum="100" Value="10" VerticalAlignment="Center" Tag="fuelStatusThresholds.red" ValueChanged="Slider_Changed"/></DockPanel></Grid>

                                    <!-- Pit Strategy -->
                                    <TextBlock Text="Pit Strategy" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Fixed Target Lap" Style="{StaticResource RowLabel}"/>
                                        <CheckBox x:Name="FuelTargetLap" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="enableTargetPitLap" Click="Toggle_Changed"/></Grid>
                                    <Border Style="{StaticResource SubGroup}" Visibility="{Binding IsChecked, ElementName=FuelTargetLap, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Target Pit Lap" Style="{StaticResource RowLabel}"/>
                                                <DockPanel Grid.Column="1">
                                                    <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=FuelTargetPitLap, Path=Value, Converter={StaticResource SliderUnit}}"/>
                                                    <Slider x:Name="FuelTargetPitLap" Minimum="1" Maximum="200" Value="15" VerticalAlignment="Center" Tag="targetPitLap" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                            <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Calculated From" Style="{StaticResource RowLabel}"/>
                                                <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="targetPitLapBasis" SelectionChanged="Combo_Changed">
                                                    <ComboBoxItem Content="Average" Tag="avg"/><ComboBoxItem Content="10-Lap Average" Tag="avg10"/><ComboBoxItem Content="Last" Tag="last"/>
                                                    <ComboBoxItem Content="Max" Tag="max"/><ComboBoxItem Content="Min" Tag="min"/><ComboBoxItem Content="Qualify" Tag="qual"/></ComboBox></Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Pitlane-Helper-Settings-Panel (adaptiert; Orientation = vertikal fix, Visibility raus) ===== -->
                    <DockPanel x:Name="PitlaneHelperPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Pitlane Helper" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Assists with pit entry: speed delta vs. pit limit, distance to pitbox, traffic, warnings and optional pit-exit input bars."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="PlhTabDisplay" GroupName="PlhTabs" Content="Display" Style="{StaticResource TabRadio}" Checked="PlhTab_Checked"/>
                                <RadioButton x:Name="PlhTabOptions" GroupName="PlhTabs" Content="Options" Style="{StaticResource TabRadio}" Checked="PlhTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- ===== DISPLAY TAB (Reorder + Format) ===== -->
                                <StackPanel x:Name="PlhDisplayTab">
                                    <TextBlock Text="Display Order" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <TextBlock Text="Drag the handle to reorder. Toggle to show/hide each section."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="PlhDisplayList" AllowDrop="True"
                                                  ItemTemplate="{StaticResource DisplayRowTemplate}"
                                                  PreviewMouseLeftButtonDown="DisplayOrderList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="DisplayOrderList_PreviewMouseMove"
                                                  DragOver="DisplayOrderList_DragOver"
                                                  Drop="DisplayOrderList_Drop"/>
                                    <Button Content="Reset to Default Order" Margin="0,10,0,0"
                                            Padding="14,6" HorizontalAlignment="Left" Cursor="Hand"
                                            Click="PlhResetDisplay_Click"/>
                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>

                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="PlhSizeWidth" Width="80" Text="150" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="PlhSizeHeight" Width="80" Text="200" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0" Padding="14,6" VerticalAlignment="Center" Cursor="Hand" Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0" Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- ===== OPTIONS TAB ===== -->
                                <StackPanel x:Name="PlhOptionsTab" Visibility="Collapsed">
                                    <!-- When to show -->
                                    <TextBlock Text="When to Show" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Mode" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="showMode" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="When approaching pit" Tag="approaching"/>
                                            <ComboBoxItem Content="Only on pit road" Tag="onPitRoad"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Approach Distance" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=PlhApproachDist, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=m}"/>
                                            <Slider x:Name="PlhApproachDist" Minimum="100" Maximum="500" Value="200" SmallChange="10" LargeChange="50" VerticalAlignment="Center" Tag="approachDistance" ValueChanged="Slider_Changed"/></DockPanel></Grid>

                                    <!-- Speed Summary Sub-Options (Enable steckt jetzt in Display Order) -->
                                    <TextBlock Text="Speed Summary" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Show Speed Delta" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Plus/minus delta against the pit limit." Style="{StaticResource RowHint}" MaxWidth="360" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="showSpeedDelta" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Speed Limit Style" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="1" VerticalAlignment="Center" Tag="speedLimitStyle" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="None" Tag="none"/>
                                            <ComboBoxItem Content="Text" Tag="text"/>
                                            <ComboBoxItem Content="European" Tag="european"/>
                                            <ComboBoxItem Content="American" Tag="american"/></ComboBox></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Speed Unit" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="speedUnit" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="Auto" Tag="auto"/>
                                            <ComboBoxItem Content="MPH" Tag="mph"/>
                                            <ComboBoxItem Content="KM/H" Tag="km/h"/></ComboBox></Grid>

                                    <!-- Progress Bar Sub-Option -->
                                    <TextBlock Text="Progress Bar" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Show Past Box" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Indicate distance past the pit box (e.g. if you missed it)." Style="{StaticResource RowHint}" MaxWidth="360" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="showPastPitBox" Click="Toggle_Changed"/></Grid>

                                    <!-- Early Pitbox Threshold (Enable steckt in Display Order) -->
                                    <TextBlock Text="Early Pitbox" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Early Warning Threshold" Style="{StaticResource RowLabel}"/>
                                            <TextBlock Text="Distance from pit entry within which the pitbox counts as early." Style="{StaticResource RowHint}" MaxWidth="360" HorizontalAlignment="Left"/></StackPanel>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=PlhEarlyThreshold, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=m}"/>
                                            <Slider x:Name="PlhEarlyThreshold" Minimum="25" Maximum="300" Value="75" SmallChange="5" LargeChange="25" VerticalAlignment="Center" Tag="earlyPitboxThreshold" ValueChanged="Slider_Changed"/></DockPanel></Grid>

                                    <!-- Pit Exit Inputs Sub-Options (Enable steckt in Display Order) -->
                                    <TextBlock Text="Pit Exit Inputs" Style="{StaticResource SectionHeader}"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Throttle" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="True" VerticalAlignment="Center" Tag="pitExitInputs.throttle" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show Clutch" Style="{StaticResource RowLabel}"/>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="pitExitInputs.clutch" Click="Toggle_Changed"/></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="When to Show" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="showInputsPhase" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="At pitbox" Tag="atPitbox"/>
                                            <ComboBoxItem Content="After pitbox" Tag="afterPitbox"/>
                                            <ComboBoxItem Content="Always (on pit road)" Tag="always"/></ComboBox></Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ===== Blind-Spot-Monitor-Settings-Panel (adaptiert; Opacity/Visibility raus) ===== -->
                    <DockPanel x:Name="BlindSpotPanel" Visibility="Collapsed" Margin="16,14">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Blind Spot Monitor" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Side indicator bar that lights up when an opponent overlaps your car. Trigger comes from iRacing's CarLeftRight signal — distances only scale the marker position within the bar."
                                       Style="{StaticResource RowHint}" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="BspTabDisplay" GroupName="BspTabs" Content="Display" Style="{StaticResource TabRadio}" Checked="BspTab_Checked"/>
                                <RadioButton x:Name="BspTabOptions" GroupName="BspTabs" Content="Options" Style="{StaticResource TabRadio}" Checked="BspTab_Checked"/>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid>
                                <!-- ===== DISPLAY TAB ===== -->
                                <StackPanel x:Name="BspDisplayTab">
                                    <TextBlock Text="Indicator" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Bar Width" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=BspWidth, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=px}"/>
                                            <Slider x:Name="BspWidth" Minimum="5" Maximum="100" Value="20" VerticalAlignment="Center" Tag="width" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Border Size" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=BspBorderSize, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=px}"/>
                                            <Slider x:Name="BspBorderSize" Minimum="0" Maximum="20" Value="1" VerticalAlignment="Center" Tag="borderSize" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Indicator Color" Style="{StaticResource RowLabel}"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="0" VerticalAlignment="Center" Tag="indicatorColor" SelectionChanged="Combo_Changed">
                                            <ComboBoxItem Content="Amber" Tag="16096779"/>
                                            <ComboBoxItem Content="Red" Tag="16711680"/>
                                            <ComboBoxItem Content="Orange" Tag="16753920"/>
                                            <ComboBoxItem Content="White" Tag="16777215"/>
                                            <ComboBoxItem Content="Green" Tag="65280"/>
                                            <ComboBoxItem Content="Cyan" Tag="65535"/>
                                        </ComboBox></Grid>

                                    <Border Height="1" Background="{StaticResource BorderTertiary}" Margin="0,16"/>

                                    <TextBlock Text="Format (px)" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Width × height — sets the VR quad aspect. Resize the Preview window, then Add to layout copies the size here."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox x:Name="BspSizeWidth" Width="80" Text="800" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="&#xD7;" VerticalAlignment="Center" Margin="10,0" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="BspSizeHeight" Width="80" Text="500" HorizontalContentAlignment="Center" LostFocus="SizeField_LostFocus" KeyDown="SizeField_KeyDown"/>
                                        <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextTertiary}"/>
                                        <Button Content="Use preview size" Margin="16,0,0,0" Padding="14,6" VerticalAlignment="Center" Cursor="Hand" Click="UsePreviewSize_Click"/>
                                    </StackPanel>
                                    <Button Content="Reset to default" Margin="0,10,0,0" Padding="14,6" HorizontalAlignment="Left" Cursor="Hand" Click="ResetFormat_Click"/>
                                </StackPanel>

                                <!-- ===== OPTIONS TAB ===== -->
                                <StackPanel x:Name="BspOptionsTab" Visibility="Collapsed">
                                    <TextBlock Text="Detection Distance" Style="{StaticResource SectionHeader}" Margin="0,4,0,6"/>
                                    <TextBlock Text="Distances (in meters) that map to the bar's full range. The marker position inside the bar scales with these; the indicator only appears when iRacing reports an overlapping car (CarLeftRight)."
                                               Style="{StaticResource RowHint}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Distance Ahead" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=BspDistAhead, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=m}"/>
                                            <Slider x:Name="BspDistAhead" Minimum="3" Maximum="6" Value="5" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Tag="distAhead" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Distance Behind" Style="{StaticResource RowLabel}"/>
                                        <DockPanel Grid.Column="1">
                                            <TextBlock DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextTertiary}" Text="{Binding ElementName=BspDistBehind, Path=Value, Converter={StaticResource SliderUnit}, ConverterParameter=m}"/>
                                            <Slider x:Name="BspDistBehind" Minimum="3" Maximum="6" Value="5" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" Tag="distBehind" ValueChanged="Slider_Changed"/></DockPanel></Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Action buttons — Copy URL rechtsbündig via DockPanel -->
        <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="False">
            <Button x:Name="AddButton" Content="Add to layout"
                    Click="AddToLayout_Click"
                    Padding="14,7" FontWeight="SemiBold" Cursor="Hand"/>
            <Button x:Name="PreviewButton" Content="Preview"
                    Click="Preview_Click"
                    Margin="8,0,0,0" Padding="14,7" Cursor="Hand"/>
            <TextBlock Text="Mock data" VerticalAlignment="Center"
                       Margin="16,0,8,0" FontSize="12"
                       Foreground="{StaticResource TextSecondary}"/>
            <CheckBox x:Name="MockToggle" Style="{StaticResource ToggleSwitch}"
                      IsChecked="True" VerticalAlignment="Center"
                      Checked="MockToggle_Changed" Unchecked="MockToggle_Changed"
                      ToolTip="Feed synthetic telemetry to the preview (no iRacing needed)"/>
            <TextBlock x:Name="StatusText" Text=""
                       VerticalAlignment="Center" Margin="14,0,14,0"
                       FontSize="13" FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextTertiary}"/>
            <Button x:Name="CopyUrlButton" Content="Copy URL"
                    DockPanel.Dock="Right"
                    Click="CopyUrl_Click"
                    Padding="14,7" Cursor="Hand"
                    ToolTip="Copy the widget URL to the clipboard (für OBS-Browser-Source o.ä.)"/>
        </DockPanel>
    </Grid>
</UserControl>
