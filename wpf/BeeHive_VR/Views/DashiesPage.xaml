                                                       Style="{StaticResource RowHint}" MaxWidth="420" HorizontalAlignment="Left"/></StackPanel>
                                        <CheckBox x:Name="RelFlagContour" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Tag="stylingOptions.flagContour.enabled" Click="Toggle_Changed"/></Grid>
