<Window x:Class="BeeHiveVR.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Confirm"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="1"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderSecondary}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="*"/>
                <!-- Body -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1" Height="32"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="Confirm"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <Button HorizontalAlignment="Right" Width="40" Height="32"
                            Click="Cancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <Path Data="M0,0 L10,10 M10,0 L0,10"
                                          Stroke="{StaticResource TextPrimary}"
                                          StrokeThickness="1"
                                          Width="10" Height="10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Body / Message -->
            <StackPanel Grid.Row="1" Margin="20,18,20,18">
                <TextBlock x:Name="MessageText"
                           Text="Are you sure?"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimary}"/>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,1,0,0" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel"
                            Padding="14,7" Margin="0,0,8,0"
                            Click="Cancel_Click"
                            MinWidth="90"/>
                    <Button x:Name="OkButton" Content="YES"
                            Style="{StaticResource AccentButton}"
                            Padding="14,7"
                            Click="Ok_Click"
                            IsDefault="True"
                            MinWidth="90"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>