<UserControl x:Class="BeeHiveVR.Views.LayoutSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BeeHiveVR.ViewModels"
             mc:Ignorable="d">

    <!--
        DataContext = MainViewModel (geerbt vom Window).
        Bindings nutzen entweder direkt MainViewModel-Properties (LayoutsView,
        SelectedLayout, ActiveLayout, SelectLayoutCommand) oder im ItemTemplate
        RelativeSource AncestorType=UserControl um zur LayoutSidebar zurück
        zu kommen — UserControl reicht hier völlig, Window wäre auch okay.
    -->

    <Border Background="{StaticResource BgSecondary}"
            BorderBrush="{StaticResource BorderTertiary}"
            BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,12">
                <TextBlock Style="{StaticResource SectionLabel}" Text="LAYOUT"/>

                <ItemsControl ItemsSource="{Binding LayoutsView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CarLayoutViewModel}">
                            <!-- Visibility-Wrapper: Default verbergen wenn AutoCreate=on -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsDefault}" Value="True"/>
                                                    <Condition Binding="{Binding DataContext.AutoCreateLayoutOnNewCar,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0,0,0,0"/>
                                        <Setter Property="Margin" Value="0,0,0,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="Margin" Value="0,0,0,4"/>
                                                <Setter Property="Padding" Value="0,0,0,4"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsLastFavorite}" Value="True">
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="Margin" Value="0,0,0,4"/>
                                                <Setter Property="Padding" Value="0,0,0,4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Border-Stripe links — nur sichtbar wenn selektiert -->
                                    <Border Grid.Column="0" Width="3"
                                            CornerRadius="0,2,2,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource RefEqualsToBool}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedLayout"
                                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background"
                                                                Value="{StaticResource AccentBgSolid}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Button Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.SelectLayoutCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LayoutItemButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource RefEqualsToBool}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedLayout"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background"
                                                            Value="{StaticResource AccentBgIntense}"/>
                                                        <Setter Property="Foreground"
                                                            Value="{StaticResource AccentText}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*" MinWidth="0"/>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Pin-Button: Klick aktiviert das Layout; volle Füllung wenn aktiv. -->
                                            <Button Grid.Column="0" Width="22" Height="22"
                                                    Style="{StaticResource IconButton}"
                                                    Click="LayoutPin_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Set as active layout">
                                                <Path Width="11" Height="11" Stretch="Uniform" StrokeThickness="2"
                                                      Data="M16 9V4 H8 V9 L5 12 V14 H19 V12 Z M11 14 V21 L12 22 L13 21 V14">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                                            <Setter Property="Fill"   Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource RefEqualsToBool}" FallbackValue="False">
                                                                            <Binding/>
                                                                            <Binding Path="DataContext.ActiveLayout"
                                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Stroke" Value="{StaticResource PinText}"/>
                                                                    <Setter Property="Fill"   Value="{StaticResource PinText}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Button>

                                            <!-- Layout-Name -->
                                            <TextBlock Grid.Column="1" Text="{Binding CarName}"
                                                   FontSize="14" VerticalAlignment="Center"
                                                   Margin="6,4,4,0" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding CarName}">
                                                <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Favoriten-Stern (nicht für Default) -->
                                        <Button Grid.Column="2" Width="22" Height="22"
                                                Style="{StaticResource IconButton}"
                                                Click="ToggleFavorite_Click"
                                                Visibility="{Binding IsDefault,
                                                    Converter={StaticResource BoolToVis},
                                                    ConverterParameter=Invert}">
                                            <Path Width="13" Height="13" Stretch="Uniform"
                                                  StrokeThickness="2"
                                                  Data="M12 2 L15.09 8.26 L22 9.27 L17 14.14 L18.18 21.02 L12 17.77 L5.82 21.02 L7 14.14 L2 9.27 L8.91 8.26 Z">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                                        <Setter Property="Fill"   Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Stroke" Value="{StaticResource AccentText}"/>
                                                                <Setter Property="Fill"   Value="{StaticResource AccentBgSolid}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Button>

                                        <!-- ... Menü-Button mit ContextMenu -->
                                        <Button Grid.Column="3" Width="22" Height="22"
                                                Style="{StaticResource IconButton}"
                                                Click="LayoutMenu_Click"
                                                Tag="{Binding}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Set as active"
                                                              Click="LayoutMenu_SetActive_Click">
                                                        <MenuItem.Icon>
                                                            <Path Width="13" Height="13" Stretch="Uniform"
                                                                  Fill="{StaticResource PinText}"
                                                                  Data="M16 9V4 H8 V9 L5 12 V14 H19 V12 Z M11 14 V21 L12 22 L13 21 V14"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Copy config"
                                                              Click="LayoutMenu_Copy_Click">
                                                        <MenuItem.Icon>
                                                            <Path Width="13" Height="13" Stretch="Uniform"
                                                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                                                  Fill="Transparent"
                                                                  Data="M9 9 H21 V21 H9 Z M5 15 H4 V4 H15 V5"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Paste config"
                                                              Click="LayoutMenu_Paste_Click">
                                                        <MenuItem.Icon>
                                                            <Path Width="13" Height="13" Stretch="Uniform"
                                                                  Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                                                  Fill="Transparent"
                                                                  Data="M16 4 H18 A2 2 0 0 1 20 6 V20 A2 2 0 0 1 18 22 H6 A2 2 0 0 1 4 20 V6 A2 2 0 0 1 6 4 H8 M8 2 H16 V6 H8 Z"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Delete layout"
                                                              Foreground="{StaticResource DangerText}"
                                                              Click="LayoutMenu_Delete_Click">
                                                        <MenuItem.Icon>
                                                            <Path Width="13" Height="13" Stretch="Uniform"
                                                                  Stroke="{StaticResource DangerText}" StrokeThickness="2"
                                                                  Fill="Transparent"
                                                                  Data="M3 6 H21 M8 6 V4 A1 1 0 0 1 9 3 H15 A1 1 0 0 1 16 4 V6 M5 6 V20 A2 2 0 0 0 7 22 H17 A2 2 0 0 0 19 20 V6 M10 11 V17 M14 11 V17"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Path Data="M5,12 A1,1 0 1,1 5,12.01 Z M12,12 A1,1 0 1,1 12,12.01 Z M19,12 A1,1 0 1,1 19,12.01 Z"
                                                  Stretch="Uniform" Fill="{StaticResource TextSecondary}"
                                                  Width="14" Height="14"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
