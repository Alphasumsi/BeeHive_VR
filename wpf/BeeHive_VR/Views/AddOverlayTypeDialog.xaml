<Window x:Class="BeeHiveVR.Views.AddOverlayTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Add overlay"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="1"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderSecondary}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1" Height="32"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Add overlay"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <Button HorizontalAlignment="Right" Width="40" Height="32"
                            Click="Cancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}">
                                    <Path Data="M0,0 L10,10 M10,0 L0,10"
                                          Stroke="{StaticResource TextPrimary}"
                                          StrokeThickness="1"
                                          Width="10" Height="10"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Body — zwei große Auswahl-Buttons -->
            <StackPanel Grid.Row="1" Margin="20,18,20,18">
                <TextBlock Text="What type of overlay?"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Browser-Auswahl -->
                    <Button Grid.Column="0" Click="Browser_Click"
                            Padding="0" Height="100"
                            Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Width="32" Height="32" Stretch="Uniform"
                                  Stroke="{StaticResource TextPrimary}" StrokeThickness="2"
                                  Fill="Transparent"
                                  Data="M12,3 A9,9 0 1,1 12,21 A9,9 0 1,1 12,3 Z M3,12 H21 M12,3 A14,14 0 0,1 12,21 M12,3 A14,14 0 0,0 12,21"/>
                            <TextBlock Text="Browser" FontSize="14" FontWeight="SemiBold"
                                       Margin="0,8,0,0" HorizontalAlignment="Center"/>
                            <TextBlock Text="HTTP URL" FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,2,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Window-Auswahl -->
                    <Button Grid.Column="2" Click="Window_Click"
                            Padding="0" Height="100"
                            Cursor="Hand">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Width="32" Height="32" Stretch="Uniform"
                                  Stroke="{StaticResource TextPrimary}" StrokeThickness="2"
                                  Fill="Transparent"
                                  Data="M3 4 H21 V20 H3 Z M3 9 H21"/>
                            <TextBlock Text="Window" FontSize="14" FontWeight="SemiBold"
                                       Margin="0,8,0,0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Existing window" FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,2,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Buttons unten -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,1,0,0" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Padding="14,7"
                            Click="Cancel_Click"
                            MinWidth="90"
                            IsCancel="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>