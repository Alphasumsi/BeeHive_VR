<UserControl x:Class="BeeHiveVR.Views.LayoutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BeeHiveVR.ViewModels"
             mc:Ignorable="d"
             Background="{StaticResource BgPrimary}">

    <!--
        DataContext = MainViewModel (geerbt vom Window).
        Der innere ScrollViewer setzt DataContext auf SelectedLayout (CarLayoutViewModel)
        damit die Bindings auf SelectedSession, Sources etc. direkt greifen.
        Über RelativeSource AncestorType=Window kommen wir jederzeit zurück
        zum MainViewModel (für ActiveLayout, Commands, HasOverlayClipboard, ...).
    -->

    <!-- Schwebende Karte im Dashies-Stil (BgSecondary, Rahmen rundum, abgerundet).
         Scroll passiert innerhalb der Karte, die Karte selbst bleibt fix. -->
    <Border DataContext="{Binding SelectedLayout}"
            Background="{StaticResource BgSecondary}"
            BorderBrush="{StaticResource BorderTertiary}"
            BorderThickness="1" CornerRadius="6"
            Margin="8,16,16,16">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14,8,14">
        <StackPanel>

            <!-- ========================================================== -->
            <!-- Tab-Header + Active-Tag rechts                              -->
            <!-- ========================================================== -->
            <Border BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1" Margin="0,0,0,10">
                <!-- Tab-Header — Active-Tag wurde in die Window-Title-Bar verschoben -->
                <StackPanel Orientation="Horizontal">
                    <Border Padding="14,8" BorderBrush="{StaticResource AccentText}"
                            BorderThickness="0,0,0,2">
                        <TextBlock Text="Overlays" FontSize="15" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ========================================================== -->
            <!-- Editing-Header                                              -->
            <!-- ========================================================== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <!-- Pencil-Icon -->
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                      Fill="Transparent"
                      VerticalAlignment="Center"
                      Data="M11 4 H4 A2 2 0 0 0 2 6 V20 A2 2 0 0 0 4 22 H18 A2 2 0 0 0 20 20 V13 M18.5 2.5 A2.121 2.121 0 0 1 21.5 5.5 L12 15 L8 16 L9 12 Z"/>
                <TextBlock Text=":" Margin="6,0,4,0" FontSize="13" FontStyle="Italic"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CarName}" FontSize="13" FontStyle="Italic"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"
                           Visibility="{Binding DataContext.EditingSpotter,
                               RelativeSource={RelativeSource AncestorType=Window},
                               Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                <TextBlock Text="Spotter (global)" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentText}"
                           VerticalAlignment="Center"
                           Visibility="{Binding DataContext.EditingSpotter,
                               RelativeSource={RelativeSource AncestorType=Window},
                               Converter={StaticResource BoolToVis}}"/>

                <!-- Live-Kontext: was gerade tatsächlich ins VR gepusht wird -->
                <Border Margin="14,0,0,0" Padding="8,2" CornerRadius="3"
                        VerticalAlignment="Center"
                        Background="{StaticResource BgElevated}"
                        BorderBrush="{StaticResource BorderTertiary}" BorderThickness="1"
                        ToolTip="Was iRacing-getrieben gerade live im VR ist (None = nichts, z.B. Garage/Laden)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LIVE:" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimary}"
                                   Text="{Binding DataContext.CurrentOverlayContext,
                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Warn-Banner wenn SelectedLayout ≠ ActiveLayout -->
            <Border Background="#3D2E1A" BorderBrush="#A07030" BorderThickness="1"
                    CornerRadius="4" Padding="10,7" Margin="0,0,0,12">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource NotRefEqualsToVis}">
                        <Binding Path="DataContext.SelectedLayout"
                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                        <Binding Path="DataContext.ActiveLayout"
                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Border.Visibility>
                <StackPanel Orientation="Horizontal">
                    <Path Width="14" Height="14" Stretch="Uniform"
                          Data="M12 2 L22 20 H2 Z M12 9 V14 M12 17 V18"
                          Stroke="#E8B070" StrokeThickness="2" Fill="Transparent"
                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#E8B070">
                        <Run Text="You are editing"/>
                        <Run Text="{Binding CarName, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=". Active layout is"/>
                        <Run Text="{Binding DataContext.ActiveLayout.CarName,
                                    RelativeSource={RelativeSource AncestorType=Window},
                                    Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="— changes here only affect this layout."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ========================================================== -->
            <!-- Session-Pills + Session-Menü                                -->
            <!-- ========================================================== -->
            <TextBlock Style="{StaticResource SectionLabel}" Text="EDIT" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,16" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- Spiegel-Modus: Edits an Sources werden in alle Sessions
                         (Practice/Qualify/Race/Test Drive) parallel geschrieben. Läuft
                         parallel zu PQR/T (kein RadioButton), Spotter schaltet ihn
                         hart aus. -->
                    <ToggleButton Content="All Sessions"
                                  ToolTip="Edits werden parallel in Practice, Qualify, Race und Test Drive übernommen. Spotter schaltet diesen Modus aus."
                                  IsChecked="{Binding EditingAllSessions, Mode=TwoWay}"
                                  Style="{StaticResource SessionPillToggleStyle}"/>
                    <Border Width="1" Margin="6,4,10,4"
                            Background="{StaticResource BorderTertiary}"/>

                    <RadioButton Content="Practice" GroupName="Session"
                                 Click="SessionPill_Click"
                                 IsChecked="{Binding SelectedSession,
                                     Converter={StaticResource EnumToBool},
                                     ConverterParameter=Practice}"
                                 Style="{StaticResource SessionPillPQRStyle}"/>
                    <RadioButton Content="Qualify" GroupName="Session"
                                 Click="SessionPill_Click"
                                 IsChecked="{Binding SelectedSession,
                                     Converter={StaticResource EnumToBool},
                                     ConverterParameter=Qualify}"
                                 Style="{StaticResource SessionPillPQRStyle}"/>
                    <RadioButton Content="Race" GroupName="Session"
                                 Click="SessionPill_Click"
                                 IsChecked="{Binding SelectedSession,
                                     Converter={StaticResource EnumToBool},
                                     ConverterParameter=Race}"
                                 Style="{StaticResource SessionPillPQRStyle}"/>

                    <!-- Kleine Lücke zwischen Race und Test Drive -->
                    <Border Width="10"/>

                    <RadioButton Content="Test Drive" GroupName="Session"
                                 ToolTip="iRacing Test Drive (SessionInfo: Offline Testing)"
                                 Click="SessionPill_Click"
                                 IsChecked="{Binding SelectedSession,
                                     Converter={StaticResource EnumToBool},
                                     ConverterParameter=TestDrive}"
                                 Style="{StaticResource SessionPillPQRStyle}"/>

                    <!-- Session ... Menü -->
                    <Button Width="22" Height="22" Margin="4,0,0,0"
                            Style="{StaticResource IconButton}"
                            VerticalAlignment="Center"
                            ToolTip="Session options"
                            IsEnabled="{Binding DataContext.EditingSpotter,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource NotBool}}"
                            Click="SessionMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="SessionMenu_FromA"
                                          Header=""
                                          Click="SessionMenu_FromA_Click"/>
                                <MenuItem x:Name="SessionMenu_FromB"
                                          Header=""
                                          Click="SessionMenu_FromB_Click"/>
                                <Separator/>
                                <MenuItem Header="Apply to all sessions"
                                          Click="SessionMenu_ApplyAll_Click"/>
                                <Separator/>
                                <MenuItem Header="Clear overlays"
                                          Foreground="{StaticResource DangerText}"
                                          Click="SessionMenu_Clear_Click">
                                    <MenuItem.Icon>
                                        <Path Width="13" Height="13" Stretch="Uniform"
                                              Stroke="{StaticResource DangerText}" StrokeThickness="2"
                                              Fill="Transparent"
                                              Data="M3 6 H21 M8 6 V4 A1 1 0 0 1 9 3 H15 A1 1 0 0 1 16 4 V6 M5 6 V20 A2 2 0 0 0 7 22 H17 A2 2 0 0 0 19 20 V6 M10 11 V17 M14 11 V17"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Path Data="M5,12 A1,1 0 1,1 5,12.01 Z M12,12 A1,1 0 1,1 12,12.01 Z M19,12 A1,1 0 1,1 19,12.01 Z"
                              Stretch="Uniform" Fill="{StaticResource TextSecondary}"
                              Width="13" Height="13"/>
                    </Button>

                    <!-- Spotter-Pill: abgesetzt vom Session-Block (eigenes globales Set) -->
                    <Border Width="1" Margin="14,4,14,4"
                            Background="{StaticResource BorderTertiary}"/>
                    <RadioButton Content="Spotter" GroupName="Session"
                                 ToolTip="Globales Spotter-Set bearbeiten (greift bei Replay / Spectator / Teamkollege fährt)"
                                 IsChecked="{Binding DataContext.EditingSpotter,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Mode=TwoWay}"
                                 Style="{StaticResource SessionPillStyle}"/>
                </StackPanel>

                <!-- Mock-Data-Toggle: rechtsbündig, nur im Edit-Header sichtbar. Schiebt
                     statische Demo-Telemetrie in alle platzierten irdashies-Overlays,
                     damit man sie beim VR-Placement auch ohne iRacing sieht. Echtes
                     iRacing pausiert den Mock automatisch. -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Mock data" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="12"
                               Foreground="{StaticResource TextSecondary}"/>
                    <CheckBox Style="{StaticResource ToggleSwitch}"
                              VerticalAlignment="Center"
                              IsChecked="{Binding DataContext.MockEnabled,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Mode=TwoWay}"
                              ToolTip="Show demo data in placed overlays so they're visible while you position them in VR. Auto-pauses when iRacing connects."/>
                </StackPanel>
            </DockPanel>

            <!-- ========================================================== -->
            <!-- Overlay-Cards                                              -->
            <!-- ========================================================== -->
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionLabel}" Text="OVERLAYS"
                           VerticalAlignment="Center"/>
                <!-- Cycle target: nur sichtbar während Source-spezifischer Place-Mode aktiv ist.
                     Alternative zum Controller-Ray wenn der User keinen passenden Trigger hat. -->
                <Button DockPanel.Dock="Right" Content="Cycle target"
                        Padding="10,4" Cursor="Hand"
                        ToolTip="Wechselt im Place-in-VR-Modus auf das nächste sichtbare Overlay."
                        Visibility="{Binding DataContext.ActivePlaceSourceId,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource NullToVis}}"
                        Command="{Binding DataContext.CyclePlaceTargetCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
            </DockPanel>

            <!-- Empty-State: nur sichtbar wenn keine Overlays -->
            <Border BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20,30"
                    Margin="0,4,0,8"
                    Background="Transparent"
                    Visibility="{Binding DataContext.EditSources,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 Converter={StaticResource CountToEmpty}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No overlays here yet"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock Text='Click "+ Add overlay" below to start.'
                               FontSize="12"
                               Foreground="{StaticResource TextTertiary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ItemsControl x:Name="OverlaysList"
                          ItemsSource="{Binding DataContext.EditSources,
                          RelativeSource={RelativeSource AncestorType=Window}}"
                          AllowDrop="True"
                          PreviewMouseLeftButtonDown="Overlays_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="Overlays_PreviewMouseMove"
                          DragOver="Overlays_DragOver"
                          Drop="Overlays_Drop">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SourceViewModel}">
                        <Border BorderThickness="1" CornerRadius="6" Margin="0,0,0,6">
                            <!-- Background/BorderBrush via Style-Setter (nicht lokal),
                                 sonst überschreiben lokale Werte die Trigger. -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource AccentBorder}"/>
                                        </DataTrigger>
                                        <!-- Drag-Hervorhebung (wie Dashies, amber) -->
                                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                            <Setter Property="Opacity" Value="0.45"/>
                                            <Setter Property="Background" Value="{StaticResource AccentBg}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentText}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Card-Header (Toggle, Icon, Name, Target, Menü, Expand) -->
                                <Grid Grid.Row="0" Margin="14,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>   <!-- 0 Z-Order -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 1 Sichtbar -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 2 Typ-Icon -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 3 Name (gedeckelt) -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 4 Status -->
                                        <ColumnDefinition Width="*"/>      <!-- 5 Target (schrumpft) -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 6 Menü -->
                                        <ColumnDefinition Width="Auto"/>   <!-- 7 Expand -->
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="1" IsChecked="{Binding Visible}"
                                              Style="{StaticResource ToggleSwitch}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>

                                    <Path Grid.Column="2" Width="15" Height="15"
                                          VerticalAlignment="Center" Margin="0,0,10,0"
                                          Stretch="Uniform" Stroke="{StaticResource TextSecondary}"
                                          StrokeThickness="2">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data"
                                                        Value="M3 4 H21 V20 H3 Z M3 9 H21"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Browser">
                                                        <Setter Property="Data"
                                                                Value="M12,3 A9,9 0 1,1 12,21 A9,9 0 1,1 12,3 Z M3,12 H21 M12,3 A14,14 0 0,1 12,21 M12,3 A14,14 0 0,0 12,21"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>

                                    <Grid Grid.Column="3" VerticalAlignment="Center" MaxWidth="240">
                                        <!-- Anzeige-Modus: TextBlock mit Doppelklick-Handler -->
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MouseLeftButtonDown="OverlayName_MouseLeftButtonDown"
                                                   Cursor="IBeam"
                                                   Visibility="{Binding IsRenaming,
                                                                Converter={StaticResource BoolToVis},
                                                                ConverterParameter=Invert}"/>
                                        <!-- Edit-Modus: TextBox mit Enter/Esc-Handlern -->
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" FontWeight="SemiBold"
                                                 HorizontalContentAlignment="Left"
                                                 BorderThickness="1"
                                                 BorderBrush="{StaticResource AccentBorder}"
                                                 Background="{StaticResource BgTertiary}"
                                                 Padding="6,3"
                                                 KeyDown="OverlayName_KeyDown"
                                                 LostFocus="OverlayName_LostFocus"
                                                 Loaded="OverlayName_Loaded"
                                                 Visibility="{Binding IsRenaming,
                                                              Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0,8,0">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                 Fill="{Binding IsMatched, Converter={StaticResource MatchToBrush}}"
                                                 ToolTip="{Binding StatusTooltip}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="5" Text="{Binding Target}"
                                               FontSize="12" FontFamily="Cascadia Mono, Consolas"
                                               Foreground="{StaticResource TextTertiary}"
                                               VerticalAlignment="Center" Margin="10,0,8,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Target}"/>

                                    <!-- Drag-Griff: Z-Order per Ziehen ändern (wie Dashies).
                                         Oben = VR-Vordergrund. -->
                                    <TextBlock Grid.Column="0" Tag="drag" Text="&#x2630;"
                                               Foreground="{StaticResource TextTertiary}"
                                               FontSize="14" Cursor="SizeAll"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               ToolTip="Ziehen zum Sortieren (Z-Order)"/>

                                    <Button Grid.Column="6" Width="24" Height="24"
                                            Style="{StaticResource IconButton}"
                                            Click="OverlayMenu_Click"
                                            Tag="{Binding}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Copy overlay"
                                                          Click="OverlayMenu_CopyOverlay_Click">
                                                    <MenuItem.Icon>
                                                        <Path Width="13" Height="13" Stretch="Uniform"
                                                              Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                                              Fill="Transparent"
                                                              Data="M9 9 H21 V21 H9 Z M5 15 H4 V4 H15 V5"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Copy position"
                                                          Click="OverlayMenu_CopyPosition_Click">
                                                    <MenuItem.Icon>
                                                        <Path Width="13" Height="13" Stretch="Uniform"
                                                              Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                                              Fill="Transparent"
                                                              Data="M12 3 V8 M9 5 L12 2 L15 5 M3 12 H8 M5 9 L2 12 L5 15 M21 12 H16 M19 9 L22 12 L19 15 M12 21 V16 M9 19 L12 22 L15 19"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Paste position"
                                                          Click="OverlayMenu_PastePosition_Click">
                                                    <MenuItem.Icon>
                                                        <Path Width="13" Height="13" Stretch="Uniform"
                                                              Stroke="{StaticResource TextSecondary}" StrokeThickness="2"
                                                              Fill="Transparent"
                                                              Data="M16 4 H18 A2 2 0 0 1 20 6 V20 A2 2 0 0 1 18 22 H6 A2 2 0 0 1 4 20 V6 A2 2 0 0 1 6 4 H8 M8 2 H16 V6 H8 Z"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Remove"
                                                          Foreground="{StaticResource DangerText}"
                                                          Click="OverlayMenu_Remove_Click">
                                                    <MenuItem.Icon>
                                                        <Path Width="13" Height="13" Stretch="Uniform"
                                                              Stroke="{StaticResource DangerText}" StrokeThickness="2"
                                                              Fill="Transparent"
                                                              Data="M3 6 H21 M8 6 V4 A1 1 0 0 1 9 3 H15 A1 1 0 0 1 16 4 V6 M5 6 V20 A2 2 0 0 0 7 22 H17 A2 2 0 0 0 19 20 V6 M10 11 V17 M14 11 V17"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Path Data="M5,12 A1,1 0 1,1 5,12.01 Z M12,12 A1,1 0 1,1 12,12.01 Z M19,12 A1,1 0 1,1 19,12.01 Z"
                                              Stretch="Uniform" Fill="{StaticResource TextSecondary}"
                                              Width="15" Height="15"/>
                                    </Button>

                                    <ToggleButton Grid.Column="7" IsChecked="{Binding IsExpanded}"
                                                  Width="24" Height="24" Margin="2,0,0,0"
                                                  BorderThickness="0" Background="Transparent"
                                                  Cursor="Hand">
                                        <Path Width="12" Height="12" Stretch="Uniform"
                                              Stroke="{StaticResource TextSecondary}"
                                              StrokeThickness="2"
                                              Data="M6,9 L12,15 L18,9"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Card-Body (Slider-Bereich, eingeklappt/ausgeklappt) -->
                                <Border Grid.Row="1" Background="{StaticResource BgTertiary}"
                                        BorderBrush="{StaticResource BorderTertiary}"
                                        BorderThickness="0,1,0,0" Padding="14,12"
                                        CornerRadius="0,0,6,6"
                                        Visibility="{Binding IsExpanded,
                                                     Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="X" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="-2" Maximum="2"
                                                    Value="{Binding X}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="X:-" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  −0.10"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="X:+" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  +0.10"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding X, StringFormat={}{0:0.000}}"
                                                     Height="26"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Y" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="-2" Maximum="2"
                                                    Value="{Binding Y}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Y:-" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  −0.10"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Y:+" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  +0.10"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Y, StringFormat={}{0:0.000}}"
                                                     Height="26"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Z" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="-3" Maximum="0"
                                                    Value="{Binding Z}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Z:-" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  −0.10"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Z:+" Click="Nudge_Click"
                                                        ToolTip="+CTRL:  +0.10"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Z, StringFormat={}{0:0.000}}"
                                                     Height="26"/>
                                        </Grid>

                                        <Border BorderBrush="{StaticResource BorderTertiary}"
                                                BorderThickness="0,1,0,0" Margin="0,0,0,10"/>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Yaw" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="-180" Maximum="180"
                                                    Value="{Binding Yaw}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Yaw:-" Click="Nudge_Click"
                                                        ToolTip="1°   +CTRL:  −5°"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Yaw:+" Click="Nudge_Click"
                                                        ToolTip="1°   +CTRL:  +5°"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Yaw, StringFormat={}{0:0.0}°}"
                                                     Height="26"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Pitch" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="-90" Maximum="90"
                                                    Value="{Binding Pitch}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Pitch:-" Click="Nudge_Click"
                                                        ToolTip="1°   +CTRL:  −5°"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Pitch:+" Click="Nudge_Click"
                                                        ToolTip="1°   +CTRL:  +5°"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Pitch, StringFormat={}{0:0.0}°}"
                                                     Height="26"/>
                                        </Grid>

                                        <Border BorderBrush="{StaticResource BorderTertiary}"
                                                BorderThickness="0,1,0,0" Margin="0,0,0,10"/>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Scale" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="1" Maximum="50"
                                                    Value="{Binding Scale, Converter={StaticResource Mult100}}"
                                                    Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Scale:-" Click="Nudge_Click"
                                                        ToolTip="1   +CTRL:  −5"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Scale:+" Click="Nudge_Click"
                                                        ToolTip="1   +CTRL:  +5"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Scale, Converter={StaticResource Mult100}, StringFormat={}{0:0.00}}"
                                                     Height="26"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="64"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacity" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                                    Value="{Binding Opacity}" Margin="6,0"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Button Tag="Opacity:-" Click="Nudge_Click"
                                                        ToolTip="1%   +CTRL:  −10%"
                                                        Width="22" Height="26" Padding="0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,2 H10"/>
                                                </Button>
                                                <Button Tag="Opacity:+" Click="Nudge_Click"
                                                        ToolTip="1%   +CTRL:  +10%"
                                                        Width="22" Height="26" Padding="0"
                                                        Margin="3,0,0,0">
                                                    <Path Stroke="{StaticResource TextPrimary}"
                                                          StrokeThickness="2"
                                                          SnapsToDevicePixels="True"
                                                          Data="M0,5 H10 M5,0 V10"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding Opacity, StringFormat={}{0:P1}}"
                                                     Height="26"/>
                                        </Grid>

                                        <!-- Browser-only: Pixelgröße fürs WebView2-Fenster.
                                             0 = Auto-Fit (vom JS gesucht; nicht zuverlässig bei fluiden Pages). -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Browser">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Browser size" FontSize="13"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding PixelWidth, UpdateSourceTrigger=LostFocus}"
                                                     Height="26"
                                                     ToolTip="Pixelbreite (0 = Auto)"/>
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding PixelHeight, UpdateSourceTrigger=LostFocus}"
                                                     Height="26"
                                                     ToolTip="Pixelhöhe (0 = Auto)"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Linke Spalte: Idle = "Place in VR", Active = Save+Cancel.
                                                 Aktiv-State steckt in SourceViewModel.IsPlacing. -->
                                            <Grid Grid.Column="0">
                                                <Button Content="Place in VR"
                                                        Style="{StaticResource AccentButton}"
                                                        Padding="10,8"
                                                        Visibility="{Binding IsPlacing,
                                                            Converter={StaticResource BoolToVis},
                                                            ConverterParameter=Invert}"
                                                        Command="{Binding DataContext.StartPlaceCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Grid Visibility="{Binding IsPlacing,
                                                          Converter={StaticResource BoolToVis}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="Save Position"
                                                            Style="{StaticResource AccentButton}"
                                                            Padding="10,8"
                                                            Command="{Binding DataContext.SavePlaceCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <Button Grid.Column="2" Content="Cancel"
                                                            Padding="10,8"
                                                            Command="{Binding DataContext.CancelPlaceCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </Grid>
                                            </Grid>
                                            <Button Grid.Column="2" Content="Reset position"
                                                    Padding="10,8"
                                                    Command="{Binding DataContext.ResetPositionCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ========================================================== -->
            <!-- Bottom-Bar (Add overlay / Paste overlay)                    -->
            <!-- ========================================================== -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Style="{StaticResource IconButton}" Padding="6,4"
                        Click="AddOverlay_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentText}"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="Add overlay" FontSize="14"
                                   Foreground="{StaticResource AccentText}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource IconButton}" Padding="6,4" Margin="14,0,0,0"
                        Click="PasteOverlay_Click"
                        Visibility="{Binding DataContext.HasOverlayClipboard,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="14"
                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Paste overlay" FontSize="14"
                                   Foreground="{StaticResource AccentText}"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
    </Border>
</UserControl>
