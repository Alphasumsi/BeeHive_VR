<UserControl x:Class="BeeHiveVR.Views.MenuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgPrimary}">

    <!--
        Platzhalter-Page. Hier wird später ein Hauptmenü/Dashboard reinkommen.
        Bild: Assets/menu_placeholder.png (Build Action: Resource).
    -->

    <Grid>
        <!-- Version oben rechts -->
        <TextBlock Text="{Binding AppVersion, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="12" Foreground="{StaticResource TextTertiary}"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,16,16,0"/>

        <!-- Hauptinhalt mittig -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Width="240" Height="240"
                   Source="pack://application:,,,/Assets/menu_placeholder.png"
                   Stretch="Uniform"
                   Margin="0,0,0,20">
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <Trigger Property="Source" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <TextBlock Text="Menu"
                       FontSize="32" FontWeight="Light"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"/>
            <TextBlock Text="Work in progress, Fehler darf man behalten"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextTertiary}"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>